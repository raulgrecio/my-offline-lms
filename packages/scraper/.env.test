# URL base de la plataforma de cursos
PLATFORM_BASE_URL=https://mylearn-mydatabase.com/

# Selector CSS que indica login exitoso (ej: el dashboard post-login)
LOGIN_SUCCESS_SELECTOR=#dashboard

# Ruta al ejecutable de Chrome del sistema (opcional)
# Por defecto Playwright intentará buscar 'chrome' en el sistema
CHROME_EXECUTABLE_PATH=/usr/bin/google-chrome

# URL de inicio para sesiones interactivas/login
SCRAPER_LOGIN_URL=https://mylearn.database.com/ou/learning-path/become-a-java-se-21-developer/138845

# Email del usuario invitado de *DATABASE* (usado para detectar si el usuario está autenticado realmente)
PLATFORM_GUEST_EMAIL=my.learn.guest@database.com

# Concurrencia de descargas paralelas (recomendado: 3-5)
DOWNLOAD_CONCURRENCY=4

# Delay entre requests en ms (respetar rate limits de la plataforma)
REQUEST_DELAY_MS=500

# ==== CONFIGURACIÓN DE DESCARGA DE GUÍAS (PDF) ====

# Crear el PDF final después de descargar las imágenes (por defecto: true)
CREATE_PDF=true
# Activa compresión de las hojas jpg bajadas usando Sharp para aligerar PDF
OPTIMIZE_IMAGES=true
# Nivel de calidad para la compresión JPG (1-100)
IMAGE_QUALITY=70
# Conservar las imágenes individuales después de crear el PDF
KEEP_TEMP_IMAGES=false

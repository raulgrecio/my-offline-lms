{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@cli/*": ["src/cli/*"],
      "@platform/*": ["src/platform/*"],
      "@features/*": ["src/features/*"],
      "@config/*": ["src/config/*"],
      "@db/*": ["src/platform/database/*"],
      "@core/*": ["../core/src/*"]
    },
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "tests/**/*", "../core/src/**/*"]
}

{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@core/*": ["../core/src/*"],
      "@scraper/*": ["../scraper/src/*"],
      "@web/*": ["src/*"],
    },
    "types": ["node", "@testing-library/jest-dom", "vitest/globals"],
    "skipLibCheck": true
  },
  "include": [".astro/types.d.ts", "./src/**/*", "./tests/**/*", "./e2e/**/*"],
  "exclude": ["node_modules", "dist"]
}

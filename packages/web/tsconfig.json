{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@core/*": ["../core/src/*"],
      "@config/*": ["src/config/*"],
      "@components/*": ["src/components/*"],
      "@features/*": ["src/features/*"],
      "@layouts/*": ["src/layouts/*"],
      "@lib/*": ["src/lib/*"],
      "@pages/*": ["src/pages/*"],
      "@platform/*": ["src/platform/*"],
      "@/*": ["src/*"],
    },
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [".astro/types.d.ts", "./src/**/*", "./tests/**/*", "./e2e/**/*"],
  "exclude": ["node_modules", "dist"]
}

{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@core/*": ["../core/src/*"]
    },
    "skipLibCheck": true
  },
  "include": [".astro/types.d.ts", "./src/**/*"],
  "exclude": ["node_modules", "dist"]
}

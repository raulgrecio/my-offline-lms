{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@my-offline-lms/scraper": ["../scraper/src/index.ts"],
      "@my-offline-lms/scraper/*": ["../scraper/src/*"],
      "@platform/*": ["src/platform/*", "../scraper/src/platform/*"],
      "@features/*": ["src/features/*", "../scraper/src/features/*"],
      "@config/*": ["src/config/*", "../scraper/src/config/*"],
      "@cli/*": ["../scraper/src/cli/*"],
      "@db/*": ["../scraper/src/platform/database/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@lib/*": ["src/lib/*"],
      "@pages/*": ["src/pages/*"],
      "@core/*": ["../core/src/*"],
      "@/*": ["src/*"],
    },
    "types": ["node", "@testing-library/jest-dom", "vitest/globals"],
    "skipLibCheck": true
  },
  "include": [".astro/types.d.ts", "./src/**/*", "./tests/**/*", "./e2e/**/*"],
  "exclude": ["node_modules", "dist"]
}

---
import Layout from "../layouts/Layout.astro";
import LearningPathCard from "../components/LearningPathCard.astro";
import CourseCard from "../components/CourseCard.astro";
import { Icon } from "../components/Icon";
import {
  getAllLearningPaths,
  getCoursesForPath,
} from "../features/learning-paths";
import { getAllCourses, getCourseById } from "../features/courses";
import {
  getAllCourseProgress,
  getLastWatchedAsset,
} from "../features/progress";
import { getActiveLearningPath } from "../features/settings";

const learningPaths = getAllLearningPaths();
const courses = getAllCourses();
const allProgress = getAllCourseProgress();
const lastWatched = getLastWatchedAsset();
const activePathId = getActiveLearningPath();

// Build progress map
const progressMap = new Map(allProgress.map((p) => [p.courseId, p.status]));

// LP completion counts
const lpStats = await Promise.all(
  learningPaths.map(async (lp) => {
    const lpCourses = getCoursesForPath(lp.id);
    const completed = lpCourses.filter(
      (c) => progressMap.get(c.id) === "completed"
    ).length;
    return { ...lp, courseCount: lpCourses.length, completedCount: completed };
  })
);

// Last watched course title
let lastWatchedCourse = lastWatched
  ? getCourseById(lastWatched.courseId)
  : null;
---

<Layout title="Inicio" description="Tu catálogo de aprendizaje offline">
  <!-- ─── Continue Watching ─────────────────────────────────────── -->
  {
    lastWatched && (
      <section class="mb-10">
        <div
          class="rounded-xl overflow-hidden"
          style="background: linear-gradient(135deg, var(--bg-surface) 0%, var(--bg-secondary) 100%); border: 1px solid var(--border-subtle); box-shadow: var(--shadow-elevation);"
        >
          <div class="p-6 sm:p-8 flex flex-col sm:flex-row items-start sm:items-center gap-5">
            <div
              class="shrink-0 w-14 h-14 rounded-2xl flex items-center justify-center transition-transform group-hover:scale-105"
              style="background-color: var(--color-brand-600); color: white; box-shadow: 0 8px 16px -4px rgba(199, 70, 52, 0.4);"
            >
              <Icon name="play" size="lg" strokeWidth={3} />
            </div>
            <div class="flex-1 min-w-0">
              <div
                class="text-xs font-semibold uppercase tracking-widest mb-1"
                style="color: var(--color-brand-400);"
              >
                Continuar viendo
              </div>
              <h2
                class="font-bold text-lg leading-snug mb-1 truncate"
                style="color: var(--color-text-primary);"
              >
                {lastWatched.metadata?.name ?? "Vídeo"}
              </h2>
              {lastWatchedCourse && (
                <p class="text-sm" style="color: var(--color-text-secondary);">
                  {lastWatchedCourse.title}
                </p>
              )}
            </div>
            <a
              href={`/courses/${lastWatched.courseId}`}
              class="btn-primary shrink-0 group"
            >
              Continuar
              <Icon
                name="chevron-right"
                size="xs"
                className="transition-transform group-hover:translate-x-1"
              />
            </a>
          </div>
        </div>
      </section>
    )
  }

  <!-- ─── Learning Paths ─────────────────────────────────────────── -->
  {
    lpStats.length > 0 && (
      <section class="mb-10">
        <div class="flex items-center justify-between mb-5">
          <h2 class="section-title">
            <Icon
              name="layers"
              size="md"
              className="text-[var(--color-brand-600)]"
            />
            Learning Paths
          </h2>
          <a href="/learning-paths" class="btn-ghost text-xs group">
            Ver todos
            <Icon
              name="chevron-right"
              size="xs"
              className="transition-transform group-hover:translate-x-1"
            />
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {lpStats.map((lp) => (
            <LearningPathCard
              id={lp.id}
              title={lp.title}
              description={lp.description}
              courseCount={lp.courseCount}
              completedCount={lp.completedCount}
              isActive={lp.id === activePathId}
            />
          ))}
        </div>
      </section>
    )
  }

  <!-- ─── All Courses ────────────────────────────────────────────── -->
  {
    courses.length > 0 && (
      <section>
        <div class="flex items-center justify-between mb-5">
          <h2 class="section-title">
            <Icon
              name="book-open"
              size="md"
              className="text-[var(--color-brand-600)]"
            />
            Todos los cursos
          </h2>
          <a href="/courses" class="btn-ghost text-xs group">
            Ver todos
            <Icon
              name="chevron-right"
              size="xs"
              className="transition-transform group-hover:translate-x-1"
            />
          </a>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
          {courses.slice(0, 8).map((course) => (
            <CourseCard
              id={course.id}
              title={course.title}
              status={progressMap.get(course.id) ?? "not_started"}
            />
          ))}
        </div>
        <div class="mt-4 text-center">
          <a href="/courses" class="btn-ghost group">
            Ver los {courses.length} cursos
            <Icon
              name="chevron-right"
              size="sm"
              className="transition-transform group-hover:translate-x-1"
            />
          </a>
        </div>
      </section>
    )
  }

  <!-- Empty state -->
  {
    courses.length === 0 && learningPaths.length === 0 && (
      <div class="text-center py-24 rounded-2xl bg-[var(--bg-secondary)] border border-dashed border-[var(--border-subtle)]">
        <div class="flex justify-center mb-4">
          <div
            class="w-16 h-16 rounded-full bg-[var(--bg-surface)] flex items-center justify-center"
            style="color: var(--text-muted);"
          >
            <Icon name="inbox" size="xl" />
          </div>
        </div>
        <h2 class="text-xl font-bold mb-2" style="color: var(--text-primary);">
          Sin contenido descargado
        </h2>
        <p class="text-sm" style="color: var(--text-secondary);">
          Ejecuta el scraper para descargar cursos y learning paths.
        </p>
      </div>
    )
  }
</Layout>

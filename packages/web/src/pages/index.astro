---
import Layout from "../layouts/Layout.astro";
import LearningPathCard from "../components/LearningPathCard.astro";
import CourseCard from "../components/CourseCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { Icon } from "../components/Icon";
import {
  getAllLearningPaths,
  getCoursesForPath,
} from "../features/learning-paths";
import { getAllCourses, getCourseById } from "../features/courses";
import {
  getAllCourseProgress,
  getLastWatchedAsset,
} from "../features/progress";
import { getActiveLearningPath } from "../features/settings";

const learningPaths = getAllLearningPaths();
const courses = getAllCourses();
const allProgress = getAllCourseProgress();
const lastWatched = getLastWatchedAsset();
const activePathId = getActiveLearningPath();

// Build progress map
const progressMap = new Map(allProgress.map((p) => [p.courseId, p.status]));

// LP completion counts
const lpStats = await Promise.all(
  learningPaths.map(async (lp) => {
    const lpCourses = getCoursesForPath(lp.id);
    const completed = lpCourses.filter(
      (c) => progressMap.get(c.id) === "completed"
    ).length;
    return { ...lp, courseCount: lpCourses.length, completedCount: completed };
  })
);

// Last watched course title
let lastWatchedCourse = lastWatched
  ? getCourseById(lastWatched.courseId)
  : null;
---

<Layout title="Inicio" description="Tu catálogo de aprendizaje offline">
  <!-- ─── Continue Watching ─────────────────────────────────────── -->
  {
    lastWatched && (
      <section class="mb-10">
        <div
          class="rounded-xl overflow-hidden bg-surface border border-border-subtle shadow-custom"
        >
          <div class="p-6 sm:p-8 flex flex-col sm:flex-row items-start sm:items-center gap-5">
            <div
              class="shrink-0 w-14 h-14 rounded-2xl flex items-center justify-center transition-transform group-hover:scale-105 bg-brand-600 text-white shadow-brand"
            >
              <Icon name="play" size="lg" strokeWidth={3} />
            </div>
            <div class="flex-1 min-w-0">
              <div
                class="text-xs font-semibold uppercase tracking-widest mb-1 text-brand-400"
              >
                Continuar viendo
              </div>
              <h2
                class="font-bold text-lg leading-snug mb-1 truncate text-text-primary"
              >
                {lastWatched.metadata?.name ?? "Vídeo"}
              </h2>
              {lastWatchedCourse && (
                <p class="text-sm text-text-secondary">
                  {lastWatchedCourse.title}
                </p>
              )}
            </div>
            <a
              href={`/courses/${lastWatched.courseId}`}
              class="btn-primary shrink-0 group"
            >
              Continuar
              <Icon
                name="chevron-right"
                size="xs"
                className="transition-transform group-hover:translate-x-1"
              />
            </a>
          </div>
        </div>
      </section>
    )
  }

  <!-- ─── Learning Paths ─────────────────────────────────────────── -->
  {
    lpStats.length > 0 && (
      <section class="mb-10">
        <SectionHeader
          title="Learning Paths"
          icon="layers"
          href="/learning-paths"
        />
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {lpStats.map((lp) => (
            <LearningPathCard
              id={lp.id}
              title={lp.title}
              description={lp.description}
              courseCount={lp.courseCount}
              completedCount={lp.completedCount}
              isActive={lp.id === activePathId}
            />
          ))}
        </div>
      </section>
    )
  }

  <!-- ─── All Courses ────────────────────────────────────────────── -->
  {
    courses.length > 0 && (
      <section>
        <SectionHeader
          title="Todos los cursos"
          icon="book-open"
          href="/courses"
        />
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
          {courses.slice(0, 8).map((course) => (
            <CourseCard
              id={course.id}
              title={course.title}
              status={progressMap.get(course.id) ?? "not_started"}
            />
          ))}
        </div>
        <div class="mt-4 text-center">
          <a href="/courses" class="btn-ghost group">
            Ver los {courses.length} cursos
            <Icon
              name="chevron-right"
              size="sm"
              className="transition-transform group-hover:translate-x-1"
            />
          </a>
        </div>
      </section>
    )
  }

  <!-- Empty state -->
  {
    courses.length === 0 && learningPaths.length === 0 && (
      <div class="text-center py-24 rounded-2xl bg-surface border border-dashed border-border-subtle">
        <div class="flex justify-center mb-4">
          <div
            class="w-16 h-16 rounded-full bg-surface-800 flex items-center justify-center text-text-muted"
          >
            <Icon name="inbox" size="xl" />
          </div>
        </div>
        <h2 class="text-xl font-bold mb-2 text-text-primary">
          Sin contenido descargado
        </h2>
        <p class="text-sm text-text-secondary">
          Ejecuta el scraper para descargar cursos y learning paths.
        </p>
      </div>
    )
  }
</Layout>

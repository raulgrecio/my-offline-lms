---
import Layout from "@layouts/Layout.astro";
import LearningPathCard from "@components/LearningPathCard.astro";
import CourseCard from "@components/CourseCard.astro";
import SectionHeader from "@components/SectionHeader.astro";
import EmptyState from "@components/EmptyState.astro";
import HomepageHero from "@components/HomepageHero.astro";
import { Icon } from "@components/Icon";
import {
  getAllLearningPaths,
  getCoursesForPath,
} from "@features/learning-paths";
import { getAllCourses, getCourseById } from "@features/courses";
import {
  getDashboardStatus,
  getLearningPathProgress,
} from "@features/progress";
import { getIsFavorite } from "@features/favorites";
import { APP_ROUTES } from "@platform/router/routes";

const learningPaths = getAllLearningPaths();
const courses = getAllCourses();
const { allProgress, lastWatched } = getDashboardStatus();

// Build progress map
const progressMap = new Map(allProgress.map((p) => [p.id, p]));

// LP progress and stats
const lpStats = await Promise.all(
  learningPaths.map(async (lp) => {
    const lpCourses = getCoursesForPath({ pathId: lp.id });
    const progress = getLearningPathProgress({ id: lp.id });

    return { 
      ...lp, 
      courseCount: lpCourses.length,
      completedCount: progress?.completedItems || 0,
      inProgressCount: progress?.inProgressItems || 0,
      progress: progress?.progress || 0,
      status: progress?.status || "not_started",
      isFavorite: getIsFavorite({ id: lp.id, type: 'learning-path' })
    };
  })
);

// Last watched course title
let lastWatchedCourse = lastWatched
  ? getCourseById({ courseId: lastWatched.courseId })
  : null;

const hasContent = courses.length > 0 || lpStats.length > 0;
---

<Layout title="Inicio" description="Tu catálogo de aprendizaje offline">
  {
    hasContent ? (
      <>
        <HomepageHero lastWatched={lastWatched} lastWatchedCourse={lastWatchedCourse} />
        
        <!-- ─── Learning Paths ─────────────────────────────────────────── -->
        {lpStats.length > 0 && (
          <section class="mb-10">
            <SectionHeader title="Learning Paths" icon="layers" href={APP_ROUTES.LEARNING_PATHS.INDEX} />
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {lpStats.map((lp) => (
                <LearningPathCard
                  id={lp.id}
                  title={lp.title}
                  description={lp.description}
                  courseCount={lp.courseCount}
                  completedCount={lp.completedCount}
                  inProgressCount={lp.inProgressCount}
                  progress={lp.progress}
                  status={lp.status}
                  isFavorite={lp.isFavorite}
                />
              ))}
            </div>
          </section>
        )}

        <!-- ─── All Courses ────────────────────────────────────────────── -->
        {courses.length > 0 && (
          <section>
            <SectionHeader id="cursos-section" title="Cursos" icon="book-open" />
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
              {courses.slice(0, 8).map((course) => {
                const progress = progressMap.get(course.id);
                const progressPercent = progress?.progress || 0;
                return (
                  <CourseCard
                    id={course.id}
                    title={course.title}
                    status={progress?.status ?? "not_started"}
                    totalAssets={progress?.totalItems}
                    progress={progressPercent}
                    isFavorite={getIsFavorite({ id: course.id, type: 'course' })}
                  />
                );
              })}
            </div>
            
            {courses.length > 8 && (
              <div class="mt-6 text-center">
                <a href={APP_ROUTES.COURSES.INDEX} class="btn btn-secondary btn-sm">
                  Ver todos los cursos
                  <Icon name="arrow-right" size="xs" className="ml-1" />
                </a>
              </div>
            )}
          </section>
        )}
      </>
    ) : (
      <EmptyState 
        title="Tu biblioteca está vacía" 
        message="Aún no tienes cursos ni rutas de aprendizaje disponibles. Sincroniza tu cuenta para empezar."
        icon="library"
      />
    )
  }
</Layout>

---
import Layout from "@web/layouts/MainLayout.astro";
import LearningPathCard from "@web/ui/components/LearningPathCard.astro";
import CourseCard from "@web/ui/components/CourseCard.astro";
import SectionHeader from "@web/ui/components/SectionHeader.astro";
import EmptyState from "@web/ui/components/EmptyState/EmptyState.astro";
import HomepageHero from "@web/ui/patterns/home/HomepageHero.astro";
import Button from "@web/ui/components/Button/Button.astro";
import {
  getAllLearningPaths,
} from "@web/features/learning-paths";
import { getAllCourses, getCourseById } from "@web/features/courses";
import {
  getDashboardStatus,
  getCourseProgress,
  getLearningPathProgress,
} from "@web/features/progress";
import { getIsFavorite } from "@web/features/favorites";
import { APP_ROUTES } from "@web/platform/router/routes";

const learningPaths = await getAllLearningPaths();
const courses = (await getAllCourses()).slice(0, 8);
const { lastWatched } = await getDashboardStatus();

// LP progress and stats
const lpStats = await Promise.all(learningPaths.map(async (lp) => {
  const [progress, isFavorite] = await Promise.all([
    getLearningPathProgress({ id: lp.id }),
    getIsFavorite({ id: lp.id, type: "learning-path" })
  ]);
  
  return {
    ...lp,
    isFavorite,
    courseCount: progress.totalItems,
    completedCount: progress.completedItems,
    inProgressCount: progress.inProgressItems,
    progress: progress.progress,
    status: progress.status,
  };
}));

// Latest courses stats
const latestCourses = await Promise.all(courses.map(async (course) => {
  const [progress, isFavorite] = await Promise.all([
    getCourseProgress({ id: course.id }),
    getIsFavorite({ id: course.id, type: "course" })
  ]);
  
  return {
    ...course,
    status: progress.status,
    totalAssets: progress.totalItems,
    progress: progress.progress,
    isFavorite
  };
}));

// Last watched course title
let lastWatchedCourse = lastWatched
  ? await getCourseById({ id: lastWatched.courseId })
  : null;

const hasContent = courses.length > 0 || lpStats.length > 0;
---

<Layout title="Inicio" description="Tu catálogo de aprendizaje offline">
  {
    hasContent ? (
      <>
        <HomepageHero lastWatched={lastWatched} lastWatchedCourse={lastWatchedCourse} />
        
        <!-- ─── Learning Paths ─────────────────────────────────────────── -->
        {lpStats.length > 0 && (
          <section class="mb-10">
            <SectionHeader title="Learning Paths" icon="layers" href={APP_ROUTES.LEARNING_PATHS.INDEX} />
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {lpStats.map((lp) => (
                <LearningPathCard
                  id={lp.id}
                  title={lp.title}
                  description={lp.description}
                  courseCount={lp.courseCount}
                  completedCount={lp.completedCount}
                  inProgressCount={lp.inProgressCount}
                  progress={lp.progress}
                  status={lp.status}
                  isFavorite={lp.isFavorite}
                />
              ))}
            </div>
          </section>
        )}

        <!-- ─── All Courses ────────────────────────────────────────────── -->
        {latestCourses.length > 0 && (
          <section>
            <SectionHeader id="cursos-section" title="Cursos" icon="book-open" />
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
              {latestCourses.map((course) => (
                <CourseCard
                  id={course.id}
                  title={course.title}
                  status={course.status}
                  totalAssets={course.totalAssets}
                  progress={course.progress}
                  isFavorite={course.isFavorite}
                />
              ))}
            </div>
            
            {courses.length > 8 && (
              <div class="mt-6 text-center">
                <Button 
                  href={APP_ROUTES.COURSES.INDEX} 
                  variant="secondary" 
                  size="sm"
                  iconRight="arrow-right"
                >
                  Ver todos los cursos
                </Button>
              </div>
            )}
          </section>
        )}
      </>
    ) : (
      <EmptyState 
        title="Tu biblioteca está vacía" 
        message="Aún no tienes cursos ni rutas de aprendizaje disponibles. Sincroniza tu cuenta para empezar."
        icon="library"
      >
        <Button 
          slot="action" 
          href={APP_ROUTES.IMPORT} 
          variant="primary" 
          icon="download"
          hoverEffect="translate"
        >
          Empezar Sincronización
        </Button>
      </EmptyState>
    )
  }
</Layout>

---
import Layout from "../layouts/Layout.astro";
import LearningPathCard from "../components/LearningPathCard.astro";
import CourseCard from "../components/CourseCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import EmptyState from "../components/EmptyState.astro";
import HomepageHero from "../components/HomepageHero.astro";
import { Icon } from "../components/Icon";
import {
  getAllLearningPaths,
  getCoursesForPath,
} from "../features/learning-paths";
import { getAllCourses, getCourseById } from "../features/courses";
import {
  getAllCourseProgress,
  getLastWatchedAsset,
  getLearningPathProgress,
} from "../features/progress";
import { getActiveLearningPath } from "../features/settings";
import { APP_ROUTES } from "../platform/router/routes";

const learningPaths = getAllLearningPaths();
const courses = getAllCourses();
const allProgress = getAllCourseProgress();
const lastWatched = getLastWatchedAsset();
const activePathId = getActiveLearningPath();

// Build progress map
const progressMap = new Map(allProgress.map((p) => [p.courseId, p]));

// LP progress and stats
const lpStats = await Promise.all(
  learningPaths.map(async (lp) => {
    const lpCourses = getCoursesForPath(lp.id);
    const progress = getLearningPathProgress(lp.id);

    //TODO: ES aqui donde deberia calcular el progreso del learning path?
    
    return { 
      ...lp, 
      courseCount: lpCourses.length,
      completedCount: progress?.completedCourses || 0,
      inProgressCount: progress?.inProgressCourses || 0,
      progress: progress?.progress || 0,
      status: progress?.status || "not_started"
    };
  })
);

// Last watched course title
let lastWatchedCourse = lastWatched
  ? getCourseById(lastWatched.courseId)
  : null;

const hasContent = courses.length > 0 || lpStats.length > 0;
---

<Layout title="Inicio" description="Tu catálogo de aprendizaje offline">
  {
    hasContent ? (
      <>
        <HomepageHero lastWatched={lastWatched} lastWatchedCourse={lastWatchedCourse} />
        
        <!-- ─── Learning Paths ─────────────────────────────────────────── -->
        {lpStats.length > 0 && (
          <section class="mb-10">
            <SectionHeader title="Learning Paths" icon="layers" href={APP_ROUTES.LEARNING_PATHS.INDEX} />
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {lpStats.map((lp) => (
                <LearningPathCard
                  id={lp.id}
                  title={lp.title}
                  description={lp.description}
                  courseCount={lp.courseCount}
                  completedCount={lp.completedCount}
                  inProgressCount={lp.inProgressCount}
                  progress={lp.progress}
                  status={lp.status}
                  isActive={lp.id === activePathId}
                />
              ))}
            </div>
          </section>
        )}

        <!-- ─── All Courses ────────────────────────────────────────────── -->
        {courses.length > 0 && (
          <section>
            <SectionHeader id="cursos-section" title="Cursos" icon="book-open" />
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
              {courses.slice(0, 8).map((course) => {
                const progress = progressMap.get(course.id);
                const progressPercent = progress?.totalAssets && progress.totalAssets > 0
                  ? Math.round((progress.completedAssets / progress.totalAssets) * 100)
                  : 0;
                return (
                  <CourseCard
                    id={course.id}
                    title={course.title}
                    status={progress?.status ?? "not_started"}
                    totalAssets={progress?.totalAssets}
                    progress={progressPercent}
                  />
                );
              })}
            </div>
            <div class="mt-4 text-center">
              <a href={APP_ROUTES.COURSES.INDEX} class="btn-ghost group">
                Ver todos los cursos
                <Icon name="chevron-right" size="sm" className="transition-transform group-hover:translate-x-1" />
              </a>
            </div>
          </section>
        )}
      </>
    ) : (
      <EmptyState
        title="Sin contenido descargado"
        message="Ejecuta el scraper para descargar cursos y learning paths."
      />
    )
  }
</Layout>

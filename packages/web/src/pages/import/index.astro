---
export const prerender = false;

import Layout from "@web/layouts/Layout.astro";
import PageHeader from "@web/components/PageHeader.astro";
import { Icon } from "@web/components/Icon";
import { LogConsole } from "@web/components/LogConsole";
import CollapsibleCard from "@web/components/CollapsibleCard.astro";

import { ScraperWizard } from "./components/ScraperWizard/_ScraperWizard";
import { TaskList } from "./components/_TaskList";
import { SessionStatus } from "./components/_SessionStatus";
import CollapsibleHeader from "@web/components/CollapsibleHeader.astro";
---

<Layout title="Importar Contenido">
  <PageHeader
    title="Centro de Importación"
    icon="download"
    subtitle="Gestiona tus cursos y rutas de aprendizaje. Sincroniza metadatos e inicia descargas de assets."
  >
    <SessionStatus client:load slot="actions" />
  </PageHeader>

  <div class="max-w-5xl mx-auto space-y-10">
    {/* Collapsible Wizard Section */}
    <section class="animate-in fade-in slide-in-from-top-4 duration-700">
      <CollapsibleCard initialOpen={false}>
        <CollapsibleHeader
          slot="header"
          icon="plus"
          title="Nueva Importación"
          subtitle="Sincroniza un curso o ruta desde la plataforma"
        />

        <div class="pt-2 pb-0">
          <ScraperWizard client:load />
        </div>
      </CollapsibleCard>
    </section>

    {/* Tasks Section */}
    <section>
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
          <h2 class="text-xl font-bold text-text-primary">Tareas en curso</h2>
        </div>
      </div>

      <TaskList client:load />
    </section>
  </div>

  {/* Live Terminal Log */}
  <section class="animate-in fade-in slide-in-from-bottom-6 duration-1000 mt-8">
    <div class="flex items-center gap-2 mb-4 px-2">
      <div class="w-2 h-2 rounded-full bg-brand-500 animate-pulse"></div>
      <h2 class="text-xs font-bold uppercase tracking-widest text-text-muted">
        Live Activity / Terminal
      </h2>
    </div>
    <LogConsole client:load />
  </section>

  {/* Help Section */}
  <section
    class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-10 border-t border-border-subtle"
  >
    <div
      class="p-8 rounded-3xl bg-surface-900 border border-border-subtle flex items-start gap-5 group hover:border-brand-500/30 transition-all"
    >
      <div
        class="p-3 rounded-2xl bg-brand-600/10 text-brand-500 group-hover:scale-110 transition-transform"
      >
        <Icon name="clock" size="md" />
      </div>
      <div>
        <h3 class="text-lg font-bold text-text-primary mb-2">
          Control de Tiempo
        </h3>
        <p class="text-sm text-text-muted leading-relaxed">
          Las sincronizaciones iniciales (metadatos) son rápidas, pero la
          descarga de vídeos y guías puede tardar dependiendo de tu conexión.
        </p>
      </div>
    </div>
    <div
      class="p-8 rounded-3xl bg-surface-900 border border-border-subtle flex items-start gap-5 group hover:border-status-completed/30 transition-all"
    >
      <div
        class="p-3 rounded-2xl bg-status-completed/10 text-status-completed group-hover:scale-110 transition-transform"
      >
        <Icon name="check-circle" size="md" />
      </div>
      <div>
        <h3 class="text-lg font-bold text-text-primary mb-2">
          Descarga Automática
        </h3>
        <p class="text-sm text-text-muted leading-relaxed">
          Una vez finalizada la descarga de un asset, el visor local se
          actualizará automáticamente con el contenido listo para usar offline.
        </p>
      </div>
    </div>
  </section>
</Layout>

<script>
  function initWizardCollapse() {
    document.addEventListener("wizard-finished", () => {
      const wizardCard = document.querySelector("[data-collapsible]");
      if (wizardCard) {
        const btn = wizardCard.querySelector(
          "[data-collapsible-trigger]",
        ) as HTMLButtonElement;
        const content = wizardCard.querySelector("[data-collapsible-content]");
        const isVisible = content && !content.classList.contains("hidden");

        if (isVisible) {
          btn.click();
        }
      }
    });
  }

  // Use both to ensure it works with Astro transitions
  initWizardCollapse();
  document.addEventListener("astro:page-load", initWizardCollapse);
</script>

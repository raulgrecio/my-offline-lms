---
export const prerender = false;

import type { GuideAsset, VideoAsset } from "@core/domain/models/Asset";

import { env } from "@config/env";
import { API_ROUTES } from "@platform/api/routes";
import { APP_ROUTES } from "@platform/router/routes";
import { getCourseById, getAssetsByCourseId } from "@features/courses";
import { getIsFavorite } from "@features/favorites";
import { getCourseProgress, getAssetProgress } from "@features/progress";
import Layout from "@layouts/Layout.astro";
import FavoriteButton from "@components/FavoriteButton.astro";
import Button from "@components/Button.astro";
import { Icon } from "@components/Icon";
import GuideCard from "@components/GuideCard.astro";
import PageHeader from "@components/PageHeader.astro";
import VideoPlaylist from "@components/VideoPlaylist.astro";
import EmptyState from "@components/EmptyState.astro";

interface CoursePageProps {
  id?: string;
}

const { id } = Astro.params as CoursePageProps;
if (!id) return Astro.redirect(APP_ROUTES.COURSES.INDEX);

const course = await getCourseById({ id });
if (!course) return Astro.redirect(APP_ROUTES.COURSES.INDEX);

const isFavorite = await getIsFavorite({ id, type: "course" });
const courseProgress = await getCourseProgress({ id });
const allAssets = await getAssetsByCourseId({ id });
const videosRaw = allAssets
  .filter(
    (a): a is VideoAsset =>
      a.type === "video" && a.status === "COMPLETED" && !!a.localPath
  )
  .sort(
    (a, b) =>
      Number(a.metadata.order_index ?? 0) - Number(b.metadata.order_index ?? 0)
  );

const guidesRaw = allAssets
  .filter(
    (a): a is GuideAsset =>
      a.type === "guide" && a.status === "COMPLETED" && !!a.localPath
  )
  .sort(
    (a, b) =>
      Number(a.metadata.order_index ?? 0) - Number(b.metadata.order_index ?? 0)
  );

// Pre-fetch progress in parallel
const videos = await Promise.all(
  videosRaw.map(async (v) => ({
    ...v,
    progress: await getAssetProgress({ assetId: v.id, type: "video" }),
  }))
);

const guides = await Promise.all(
  guidesRaw.map(async (g) => ({
    ...g,
    progress: await getAssetProgress({ assetId: g.id, type: "guide" }),
  }))
);

// Find the active video
const videoId = Astro.url.searchParams.get("v");
const activeVideo = videoId
  ? videos.find((v) => v.id === videoId) || videos[0]
  : videos[0];

// Generate file:// URL for local assets
function localUrl(localPath: string): string {
  return API_ROUTES.ASSETS.LOCAL_ASSET(localPath);
}

function subtitleUrl(videoLocalPath: string): string | undefined {
  const base = videoLocalPath.replace(/\.(mp4|mkv|webm)$/i, "");
  const subtitlePath = `${base}.${env.SUBTITLE_LANGUAGE}.vtt`;
  return API_ROUTES.ASSETS.LOCAL_ASSET(subtitlePath);
}

const hasVideos = videos.length > 0;
const hasGuides = guides.length > 0;
const hasContent = hasVideos || hasGuides;

const videosList = videos.map((v) => ({
  id: v.id,
  title: v.metadata?.name ?? v.id,
  src: localUrl(v.localPath!),
  subtitleSrc: subtitleUrl(v.localPath!),
  duration: v.metadata?.duration || 0,
  progress: v.progress,
}));
---

<Layout title={course.title}>
  <div
    id="course-page-context"
    data-course-id={id}
    data-progress-url={API_ROUTES.PROGRESS.COURSE}
    data-metadata-url={API_ROUTES.ASSETS.METADATA()}
  >
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-xs mb-6 text-text-muted">
      <a
        href={APP_ROUTES.HOME}
        class="text-text-muted no-underline hover:underline">Inicio</a
      >
      <Icon name="chevron-right" size="xs" />
      <a
        href={APP_ROUTES.COURSES.INDEX}
        class="text-text-muted no-underline hover:underline">Cursos</a
      >
      <Icon name="chevron-right" size="xs" />
      <span class="text-text-secondary">{course.title}</span>
    </nav>

    <!-- Header -->
    <PageHeader
      title={course.title}
      icon="book-open"
      status={courseProgress?.status ?? "not_started"}
      subtext={`${videos.length} vídeos · ${guides.length} guías`}
    >
      <div slot="actions" class="flex items-center gap-4">
        <FavoriteButton
          id={id}
          type="course"
          isFavorite={isFavorite}
          size="md"
          hoverEffect="translate"
          className="border border-border-subtle bg-surface-800"
        />

        <Button
          id="btn-complete"
          variant="primary"
          hoverEffect="translate"
          icon="check-circle"
          data-course-id={id}
          size="md"
          data-completed={courseProgress?.status === "completed"
            ? "true"
            : "false"}
        >
          {
            courseProgress?.status === "completed"
              ? "Completado"
              : "Marcar completado"
          }
        </Button>
      </div>
    </PageHeader>

    <!-- ─── Videos ──────────────────────────────────────────────────────── -->
    {
      hasContent && hasVideos && (
        <VideoPlaylist
          videos={videosList}
          activeVideoId={activeVideo?.id}
          courseId={id}
          progressUrl={API_ROUTES.PROGRESS.VIDEO}
        />
      )
    }

    <!-- ─── Guides ──────────────────────────────────────────────────────── -->
    {
      hasContent && hasGuides && (
        <section class="mb-10">
          <h2 class="section-title mb-5">
            <Icon name="file-text" size="md" className="text-brand-600" />
            Guías ({guides.length})
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {guides.map((g, i) => (
              <GuideCard
                assetId={g.id}
                courseId={id}
                name={
                  g.metadata?.name ?? g.metadata?.filename ?? `Guía ${i + 1}`
                }
                localUrl={localUrl(g.localPath!)}
                progress={g.progress}
                totalPages={g.metadata?.totalPages}
              />
            ))}
          </div>
        </section>
      )
    }

    {
      !hasContent && (
        <EmptyState
          icon="inbox"
          message="No hay assets descargados para este curso."
        />
      )
    }
  </div>
</Layout>

<script>
  // Route relative imports
  import { apiClient } from "@platform/api/client";
  import { logger } from "@platform/logging";

  const context = document.getElementById("course-page-context") as HTMLElement;
  const COURSE_PROGRESS_URL = context.dataset.progressUrl!;
  const METADATA_URL = context.dataset.metadataUrl!;

  // ─── Mark complete button ─────────────────────────────────────────────
  const btnComplete = document.getElementById(
    "btn-complete"
  ) as HTMLButtonElement | null;
  btnComplete?.addEventListener("click", async () => {
    const courseId = btnComplete.dataset.courseId!;
    const isCompleted = btnComplete.dataset.completed === "true";
    const newStatus = isCompleted ? "in_progress" : "completed";

    try {
      await apiClient.post(COURSE_PROGRESS_URL, {
        courseId,
        status: newStatus,
      });
      window.location.reload();
    } catch (err) {
      logger.error("Failed to update course progress:", err);
    }
  });

  // ─── Metadata Polling ─────────────────────────────────────────────────────
  const missingMetadataCards = document.querySelectorAll<HTMLElement>(
    '[data-missing-metadata="true"]'
  );

  if (missingMetadataCards.length > 0) {
    const refreshMetadata = async (card: HTMLElement) => {
      const assetId = card.dataset.assetId;
      try {
        const metadata = await apiClient.get<any>(
          `${METADATA_URL}?assetId=${assetId}`
        );
        if (metadata && metadata.totalPages) {
          const statusLabel = card.querySelector(".status-label");
          const isDone = card.dataset.isDone === "true";
          const currentPage = parseInt(card.dataset.currentPage || "0");
          const totalPages = metadata.totalPages;

          if (statusLabel) {
            if (isDone) {
              statusLabel.textContent = "Completado";
            } else if (currentPage > 1) {
              statusLabel.textContent = `Página ${currentPage} de ${totalPages}`;
            } else {
              statusLabel.textContent = `Ver guía de ${totalPages} páginas`;
            }
          }
          card.dataset.missingMetadata = "false";
          return true;
        }
      } catch (e) {
        logger.error("Error polling metadata:", e);
      }
      return false;
    };

    const pollAll = async () => {
      const remaining = document.querySelectorAll<HTMLElement>(
        '[data-missing-metadata="true"]'
      );
      if (remaining.length === 0) return;

      for (const card of remaining) {
        await refreshMetadata(card);
      }
    };

    // Poll on visibility change (re-focusing the course page after closing the PDF)
    document.addEventListener("visibilitychange", () => {
      if (document.visibilityState === "visible") {
        pollAll();
      }
    });

    // Initial soft polling after returning
    setTimeout(pollAll, 1500);
    setTimeout(pollAll, 4000);
  }
</script>

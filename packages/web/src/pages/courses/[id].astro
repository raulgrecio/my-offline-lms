---
export const prerender = false;

import type { GuideAsset, VideoAsset } from "@core/domain/models/Asset";

import { env } from "../../config/env";
import Layout from '../../layouts/Layout.astro';
import ProgressBadge from '../../components/ProgressBadge.astro';
import VideoPlayer from '../../components/VideoPlayer';
import { Icon } from '../../components/Icon';
import GuideCard from "../../components/GuideCard.astro";
import {
  getCourseById,
  getCourseAssets,
} from "../../features/courses";
import {
  getCourseProgress,
  getVideoProgress,
} from "../../features/progress";

const { id } = Astro.params;
if (!id) return Astro.redirect('/courses');

const course = getCourseById(id);
if (!course) return Astro.redirect('/courses');

const allAssets = getCourseAssets(id);
const videos = allAssets
  .filter((a): a is VideoAsset => a.type === 'video' && a.status === 'COMPLETED' && !!a.localPath)
  .sort((a, b) => Number(a.metadata.order_index ?? 0) - Number(b.metadata.order_index ?? 0));

const guides = allAssets
  .filter((a): a is GuideAsset => a.type === 'guide' && a.status === 'COMPLETED' && !!a.localPath)
  .sort((a, b) => Number(a.metadata.order_index ?? 0) - Number(b.metadata.order_index ?? 0));

const courseProgress = getCourseProgress(id);

// Pre-fetch all video progress
const videoProgressMap = new Map(
  videos.map(v => [v.id, getVideoProgress(v.id)])
);

// Find the active video
const videoId = Astro.url.searchParams.get('v');
const activeVideo = videoId
  ? (videos.find(v => v.id === videoId) || videos[0])
  : videos[0];

// Generate file:// URL for local assets
function localUrl(localPath: string): string {
  // Strip leading /home/... to a relative /assets/... if needed
  // We serve files from /data via a static route
  return `/api/asset/local-asset?path=${encodeURIComponent(localPath)}`;
}

function subtitleUrl(videoLocalPath: string): string | undefined {
  const base = videoLocalPath.replace(/\.(mp4|mkv|webm)$/i, '');
  const subtitlePath = `${base}.${env.SUBTITLE_LANGUAGE}.vtt`;
  return `/api/asset/local-asset?path=${encodeURIComponent(subtitlePath)}`;
} 
---

<Layout title={course.title}>
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-xs mb-6 text-text-muted">
    <a href="/" class="text-text-muted no-underline hover:underline">Inicio</a>
    <Icon name="chevron-right" size="xs" />
    <a href="/courses" class="text-text-muted no-underline hover:underline">Cursos</a>
    <Icon name="chevron-right" size="xs" />
    <span class="text-text-secondary">{course.title}</span>
  </nav>

  <!-- Course header -->
  <div class="flex flex-col sm:flex-row items-start gap-4 mb-8">
    <div
      class="shrink-0 w-14 h-14 rounded-xl flex items-center justify-center transition-transform hover:scale-105 bg-surface-900 text-brand-600 border border-border-subtle"
    >
      <Icon name="book-open" size="xl" />
    </div>
    <div class="flex-1 min-w-0">
      <h1 class="text-xl sm:text-2xl font-bold leading-snug mb-2 text-text-primary">
        {course.title}
      </h1>
      <div class="flex items-center gap-3 flex-wrap">
        <ProgressBadge status={courseProgress?.status ?? 'not_started'} />
        <span class="text-xs text-text-muted">
          {videos.length} vídeos · {guides.length} guías
        </span>
      </div>
    </div>
    <!-- Mark complete button -->
    <button
      id="btn-complete"
      data-course-id={id}
      class="btn-primary shrink-0 sm:self-start"
      data-completed={courseProgress?.status === 'completed' ? 'true' : 'false'}
    >
      <Icon name="check-circle" size="sm" />
      {courseProgress?.status === 'completed' ? 'Completado' : 'Marcar completado'}
    </button>
  </div>

  <hr class="divider mb-8" />

  <!-- ─── Videos ──────────────────────────────────────────────────────── -->
  {videos.length > 0 && (
    <section class="mb-10">
      <h2 class="section-title mb-5">
        <Icon name="play" size="md" className="text-brand-600" />
        Vídeos ({videos.length})
      </h2>

      <div class="flex flex-col lg:flex-row gap-6">
        <!-- Player panel -->
        <div class="flex-1 min-w-0">
          <div id="player-container">
            {activeVideo && (
              <VideoPlayer
                client:load
                assetId={activeVideo.id}
                src={localUrl(activeVideo.localPath!)}
                title={activeVideo.metadata?.name ?? activeVideo.id}
                subtitleSrc={subtitleUrl(activeVideo.localPath!)}
                initialPosition={videoProgressMap.get(activeVideo.id)?.positionSec ?? 0}
                initialDuration={activeVideo.metadata?.duration ?? 0}
              />
            )}
          </div>
          <p id="player-title" class="text-sm font-medium mt-3 text-text-primary">
            {activeVideo?.metadata?.name ?? ''}
          </p>
        </div>

        <!-- Video list -->
        <div
          class="lg:w-80 xl:w-96 flex flex-col rounded-xl bg-surface-800 border border-border-subtle shadow-custom max-h-[500px] overflow-hidden"
        >
          <div class="p-3 border-b text-[10px] font-bold uppercase tracking-widest text-text-muted border-border-subtle shrink-0 bg-surface-800/50 backdrop-blur-sm">
            Contenido del curso
          </div>
          <div class="overflow-y-auto flex-1 custom-scrollbar">
            {videos.map((v, i) => {
              const vp = videoProgressMap.get(v.id);
              const isDone = vp?.completed;
              const isActive = v.id === activeVideo?.id;
              return (
                <button
                  class={`video-item w-full text-left flex items-start gap-3 p-3 transition-all hover:bg-surface-900 border-b border-border-subtle last:border-b-0 cursor-pointer ${
                    isActive ? 'bg-surface-700' : 'bg-transparent'
                  }`}
                  data-src={localUrl(v.localPath!)}
                  data-asset-id={v.id}
                  data-title={v.metadata?.name ?? v.id}
                  data-subtitle={subtitleUrl(v.localPath!)}
                  data-position={vp?.positionSec ?? 0}
                >
                <div
                  class={`shrink-0 w-7 h-7 rounded-full flex items-center justify-center text-[10px] font-bold mt-0.5 ${
                    isDone
                      ? 'bg-brand-600 text-white'
                      : 'bg-surface-600 text-text-muted'
                  }`}
                >
                  {isDone ? <Icon name="check-circle" size="xs" strokeWidth={3} /> : i + 1}
                </div>
                <div class="flex-1 min-w-0">
                  <p class={`text-xs leading-snug line-clamp-2 transition-colors ${isActive ? 'text-text-primary font-semibold' : 'text-text-secondary'}`}>
                    {v.metadata?.name ?? `Vídeo ${i + 1}`}
                  </p>
                  {vp && !vp.completed && vp.positionSec > 0 && (
                    <p class="text-[10px] mt-1 flex items-center gap-1 font-semibold text-brand-600">
                      <Icon name="play" size="xs" />
                      Continuar: {Math.floor(vp.positionSec / 60)}:{String(Math.floor(vp.positionSec % 60)).padStart(2,'0')}
                    </p>
                  )}
                </div>
              </button>
            );
          })}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ─── Guides ──────────────────────────────────────────────────────── -->
  {guides.length > 0 && (
    <section class="mb-10">
      <h2 class="section-title mb-5">
        <Icon name="file-text" size="md" className="text-brand-600" />
        Guías ({guides.length})
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {guides.map((g, i) => (
          <GuideCard
            name={g.metadata?.name ?? g.metadata?.filename ?? `Guía ${i + 1}`}
            localUrl={localUrl(g.localPath!)}
          />
        ))}
      </div>
    </section>
  )}

  {videos.length === 0 && guides.length === 0 && (
    <div class="text-center py-24 rounded-2xl bg-surface-900 border border-dashed border-border-subtle">
      <div class="flex justify-center mb-4">
        <div class="w-16 h-16 rounded-full bg-surface-800 flex items-center justify-center text-text-muted">
          <Icon name="inbox" size="xl" />
        </div>
      </div>
      <p class="font-medium text-sm text-text-secondary">Sin assets descargados para este curso.</p>
    </div>
  )}
</Layout>

<script>
  // ─── Video playlist switching ────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.video-item').forEach(btn => {
    btn.addEventListener('click', () => {
      const assetId = btn.dataset.assetId!;
      const url = new URL(window.location.href);
      url.searchParams.set('v', assetId);
      window.location.href = url.toString();
    });
  });

  // ─── Mark complete button ─────────────────────────────────────────────
  const btnComplete = document.getElementById('btn-complete') as HTMLButtonElement | null;
  btnComplete?.addEventListener('click', async () => {
    const courseId = btnComplete.dataset.courseId!;
    const isCompleted = btnComplete.dataset.completed === 'true';
    const newStatus = isCompleted ? 'in_progress' : 'completed';

    const res = await fetch('/api/progress/course', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ courseId, status: newStatus }),
    });

    if (res.ok) {
      window.location.reload();
    }
  });
</script>

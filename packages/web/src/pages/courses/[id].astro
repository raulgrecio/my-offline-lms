---
export const prerender = false;

import { env } from "../../config/env";
import Layout from '../../layouts/Layout.astro';
import ProgressBadge from '../../components/ProgressBadge.astro';
import VideoPlayer from '../../components/VideoPlayer';
import { Icon } from '../../components/Icon';
import {
  getCourseById,
  getCourseAssets,
} from "../../features/courses";
import {
  getCourseProgress,
  getVideoProgress,
} from "../../features/progress";

const { id } = Astro.params;
if (!id) return Astro.redirect('/courses');

const course = getCourseById(id);
if (!course) return Astro.redirect('/courses');

const allAssets = getCourseAssets(id);
const videos = allAssets
.filter(a => a.type === 'video' && a.status === 'COMPLETED' && a.localPath)
.sort((a, b) => Number(a.metadata.order_index ?? 0) - Number(b.metadata.order_index ?? 0));

const guides = allAssets
.filter(a => a.type === 'guide' && a.status === 'COMPLETED' && a.localPath)
.sort((a, b) => Number(a.metadata.order_index ?? 0) - Number(b.metadata.order_index ?? 0));

const courseProgress = getCourseProgress(id);

// Pre-fetch all video progress
const videoProgressMap = new Map(
  videos.map(v => [v.id, getVideoProgress(v.id)])
);

// Find the active video
const videoId = Astro.url.searchParams.get('v');
const activeVideo = videoId
  ? (videos.find(v => v.id === videoId) || videos[0])
  : videos[0];

// Generate file:// URL for local assets
function localUrl(localPath: string): string {
  // Strip leading /home/... to a relative /assets/... if needed
  // We serve files from /data via a static route
  return `/local-asset?path=${encodeURIComponent(localPath)}`;
}

function subtitleUrl(videoLocalPath: string): string | undefined {
  const base = videoLocalPath.replace(/\.(mp4|mkv|webm)$/i, '');
  const subtitlePath = `${base}.${env.SUBTITLE_LANGUAGE}.vtt`;
  return `/local-asset?path=${encodeURIComponent(subtitlePath)}`;
} 
---

<Layout title={course.title}>
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-xs mb-6" style="color: var(--text-muted);">
    <a href="/" style="color: var(--text-muted); text-decoration: none;" class="hover:underline">Inicio</a>
    <Icon name="chevron-right" size="xs" />
    <a href="/courses" style="color: var(--text-muted); text-decoration: none;" class="hover:underline">Cursos</a>
    <Icon name="chevron-right" size="xs" />
    <span style="color: var(--text-secondary);">{course.title}</span>
  </nav>

  <!-- Course header -->
  <div class="flex flex-col sm:flex-row items-start gap-4 mb-8">
    <div
      class="shrink-0 w-14 h-14 rounded-xl flex items-center justify-center transition-transform hover:scale-105"
      style="background-color: var(--bg-secondary); color: var(--color-brand-600); border: 1px solid var(--border-subtle);"
    >
      <Icon name="book-open" size="xl" />
    </div>
    <div class="flex-1 min-w-0">
      <h1 class="text-xl sm:text-2xl font-bold leading-snug mb-2" style="color: var(--text-primary);">
        {course.title}
      </h1>
      <div class="flex items-center gap-3 flex-wrap">
        <ProgressBadge status={courseProgress?.status ?? 'not_started'} />
        <span class="text-xs" style="color: var(--text-muted);">
          {videos.length} vídeos · {guides.length} guías
        </span>
      </div>
    </div>
    <!-- Mark complete button -->
    <button
      id="btn-complete"
      data-course-id={id}
      class="btn-primary shrink-0 sm:self-start"
      data-completed={courseProgress?.status === 'completed' ? 'true' : 'false'}
    >
      <Icon name="check-circle" size="sm" />
      {courseProgress?.status === 'completed' ? 'Completado' : 'Marcar completado'}
    </button>
  </div>

  <hr class="divider mb-8" />

  <!-- ─── Videos ──────────────────────────────────────────────────────── -->
  {videos.length > 0 && (
    <section class="mb-10">
      <h2 class="section-title mb-5">
        <Icon name="play" size="md" className="text-[var(--color-brand-600)]" />
        Vídeos ({videos.length})
      </h2>

      <div class="flex flex-col lg:flex-row gap-6">
        <!-- Player panel -->
        <div class="flex-1 min-w-0">
          <div id="player-container">
            {activeVideo && (
              <VideoPlayer
                client:load
                assetId={activeVideo.id}
                src={localUrl(activeVideo.localPath!)}
                title={activeVideo.metadata?.name ?? activeVideo.id}
                subtitleSrc={subtitleUrl(activeVideo.localPath!)}
                initialPosition={videoProgressMap.get(activeVideo.id)?.positionSec ?? 0}
              />
            )}
          </div>
          <p id="player-title" class="text-sm font-medium mt-3" style="color: var(--text-primary);">
            {activeVideo?.metadata?.name ?? ''}
          </p>
        </div>

        <!-- Video list -->
        <div
          class="lg:w-80 xl:w-96 overflow-y-auto rounded-xl"
          style="background-color: var(--bg-surface); border: 1px solid var(--border-subtle); max-height: 400px; box-shadow: var(--shadow-elevation);"
        >
          <div class="p-3 border-b text-[10px] font-bold uppercase tracking-widest" style="color: var(--text-muted); border-color: var(--border-subtle);">
            Contenido del curso
          </div>
            {videos.map((v, i) => {
              const vp = videoProgressMap.get(v.id);
              const isDone = vp?.completed;
              const isActive = v.id === activeVideo?.id;
              return (
                <button
                  class="video-item w-full text-left flex items-start gap-3 p-3 transition-all hover:bg-[var(--bg-secondary)]"
                  style={`border-bottom: 1px solid var(--border-subtle); cursor: pointer; ${
                    isActive ? 'background-color: var(--bg-surface-active);' : 'background: none;'
                  }`}
                  data-src={localUrl(v.localPath!)}
                  data-asset-id={v.id}
                  data-title={v.metadata?.name ?? v.id}
                  data-subtitle={subtitleUrl(v.localPath!)}
                  data-position={vp?.positionSec ?? 0}
                >
                <div
                  class="shrink-0 w-7 h-7 rounded-full flex items-center justify-center text-[10px] font-bold mt-0.5"
                  style={isDone
                    ? 'background-color: var(--color-brand-600); color: white;'
                    : 'background-color: var(--bg-surface-active); color: var(--text-muted);'}
                >
                  {isDone ? <Icon name="check-circle" size="xs" strokeWidth={3} /> : i + 1}
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-xs leading-snug line-clamp-2 transition-colors" style={isActive ? 'color: var(--text-primary); font-weight: 600;' : 'color: var(--text-secondary);'}>
                    {v.metadata?.name ?? `Vídeo ${i + 1}`}
                  </p>
                  {vp && !vp.completed && vp.positionSec > 0 && (
                    <p class="text-[10px] mt-1 flex items-center gap-1 font-semibold" style="color: var(--color-brand-600);">
                      <Icon name="play" size="xs" />
                      Continuar: {Math.floor(vp.positionSec / 60)}:{String(Math.floor(vp.positionSec % 60)).padStart(2,'0')}
                    </p>
                  )}
                </div>
              </button>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ─── Guides ──────────────────────────────────────────────────────── -->
  {guides.length > 0 && (
    <section class="mb-10">
      <h2 class="section-title mb-5">
        <Icon name="file-text" size="md" className="text-[var(--color-brand-600)]" />
        Guías ({guides.length})
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {guides.map((g, i) => (
          <a
            href={localUrl(g.localPath!)}
            target="_blank"
            rel="noopener"
            class="card flex items-center gap-3 p-4"
            style="text-decoration: none;"
          >
            <div
              class="shrink-0 w-10 h-10 rounded-xl flex items-center justify-center transition-transform group-hover:scale-110"
              style="background-color: var(--bg-secondary); color: var(--color-brand-600); border: 1px solid var(--border-subtle);"
            >
              <Icon name="file-text" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium line-clamp-2" style="color: var(--text-primary);">
                {g.metadata?.name ?? g.metadata?.filename ?? `Guía ${i + 1}`}
              </p>
              <div class="flex items-center gap-1.5 mt-1">
                <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-[var(--bg-secondary)]" style="color: var(--text-muted);">PDF</span>
                <span class="text-[10px]" style="color: var(--text-muted);">Ver guía</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {videos.length === 0 && guides.length === 0 && (
    <div class="text-center py-24 rounded-2xl bg-[var(--bg-secondary)] border border-dashed border-[var(--border-subtle)]">
      <div class="flex justify-center mb-4">
        <div class="w-16 h-16 rounded-full bg-[var(--bg-surface)] flex items-center justify-center" style="color: var(--text-muted);">
          <Icon name="inbox" size="xl" />
        </div>
      </div>
      <p style="color: var(--text-secondary);" class="font-medium text-sm">Sin assets descargados para este curso.</p>
    </div>
  )}
</Layout>

<script>
  // ─── Video playlist switching ────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.video-item').forEach(btn => {
    btn.addEventListener('click', () => {
      const assetId = btn.dataset.assetId!;
      const url = new URL(window.location.href);
      url.searchParams.set('v', assetId);
      window.location.href = url.toString();
    });
  });

  // ─── Mark complete button ─────────────────────────────────────────────
  const btnComplete = document.getElementById('btn-complete') as HTMLButtonElement | null;
  btnComplete?.addEventListener('click', async () => {
    const courseId = btnComplete.dataset.courseId!;
    const isCompleted = btnComplete.dataset.completed === 'true';
    const newStatus = isCompleted ? 'in_progress' : 'completed';

    const res = await fetch('/api/progress/course', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ courseId, status: newStatus }),
    });

    if (res.ok) {
      window.location.reload();
    }
  });
</script>

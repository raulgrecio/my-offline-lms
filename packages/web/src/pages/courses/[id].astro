---
export const prerender = false;

import type { GuideAsset, VideoAsset } from "@core/domain/models/Asset";

import { env } from "../../config/env";
import Layout from '../../layouts/Layout.astro';
import VideoPlayer from '../../components/VideoPlayer';
import { Icon } from '../../components/Icon';
import FavoriteButton from "../../components/FavoriteButton.astro";
import GuideCard from "../../components/GuideCard.astro";
import PageHeader from "../../components/PageHeader.astro";
import {
  getCourseById,
  getCourseAssets,
} from "../../features/courses";
import {
  getCourseProgress,
  getAssetProgress,
} from "../../features/progress";
import { getIsFavorite } from "../../features/favorites";
import { API_ROUTES } from "../../platform/api/routes";
import { APP_ROUTES } from "../../platform/router/routes";


interface CoursePageProps {
  id?: string;
}

const { id } = Astro.params as CoursePageProps;
if (!id) return Astro.redirect(APP_ROUTES.COURSES.INDEX);

const course = getCourseById({ courseId: id });
if (!course) return Astro.redirect(APP_ROUTES.COURSES.INDEX);

const isFavorite = getIsFavorite(id, 'course');

const allAssets = getCourseAssets({ courseId: id });
const videos = allAssets
  .filter((a): a is VideoAsset => a.type === 'video' && a.status === 'COMPLETED' && !!a.localPath)
  .sort((a, b) => Number(a.metadata.order_index ?? 0) - Number(b.metadata.order_index ?? 0));

const guides = allAssets
  .filter((a): a is GuideAsset => a.type === 'guide' && a.status === 'COMPLETED' && !!a.localPath)
  .sort((a, b) => Number(a.metadata.order_index ?? 0) - Number(b.metadata.order_index ?? 0));

const courseProgress = getCourseProgress({ courseId: id });

// Pre-fetch all video progress
const videoProgressMap = new Map(
  videos.map(video => [video.id, getAssetProgress({ assetId: video.id })])
);

// Pre-fetch all guide progress
const guideProgressMap = new Map(
  guides.map(guide => [guide.id, getAssetProgress({ assetId: guide.id })])
);

// Find the active video
const videoId = Astro.url.searchParams.get('v');
const activeVideo = videoId
  ? (videos.find(v => v.id === videoId) || videos[0])
  : videos[0];

// Generate file:// URL for local assets
function localUrl(localPath: string): string {
  return API_ROUTES.ASSETS.LOCAL_ASSET(localPath);
}

function subtitleUrl(videoLocalPath: string): string | undefined {
  const base = videoLocalPath.replace(/\.(mp4|mkv|webm)$/i, '');
  const subtitlePath = `${base}.${env.SUBTITLE_LANGUAGE}.vtt`;
  return API_ROUTES.ASSETS.LOCAL_ASSET(subtitlePath);
} 
---

<Layout title={course.title}>
  <div 
    id="course-page-context" 
    data-course-id={id}
    data-progress-url={API_ROUTES.PROGRESS.COURSE}
    data-metadata-url={API_ROUTES.ASSETS.METADATA()}
  >
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-xs mb-6 text-text-muted">
    <a href={APP_ROUTES.HOME} class="text-text-muted no-underline hover:underline">Inicio</a>
    <Icon name="chevron-right" size="xs" />
    <a href={APP_ROUTES.COURSES.INDEX} class="text-text-muted no-underline hover:underline">Cursos</a>
    <Icon name="chevron-right" size="xs" />
    <span class="text-text-secondary">{course.title}</span>
  </nav>

  <!-- Header -->
  <!-- Header -->
  <PageHeader
    title={course.title}
    icon="book-open"
    status={courseProgress?.status ?? 'not_started'}
    subtext={`${videos.length} vídeos · ${guides.length} guías`}
  >
    <div slot="actions">
      <FavoriteButton 
        id={id} 
        type="course" 
        isFavorite={isFavorite} 
        size="lg" 
        hoverEffect="translate"
        className="border border-border-subtle bg-surface-800"
      />

      <button
        id="btn-complete"
        data-course-id={id}
        class="btn-primary"
        data-completed={courseProgress?.status === 'completed' ? 'true' : 'false'}
      >
        <Icon name="check-circle" size="sm" />
        {courseProgress?.status === 'completed' ? 'Completado' : 'Marcar completado'}
      </button>
    </div>
  </PageHeader>

  <hr class="divider mb-8" />

  <!-- ─── Videos ──────────────────────────────────────────────────────── -->
  {videos.length > 0 && (
    <section class="mb-10">
      <h2 class="section-title mb-5">
        <Icon name="play" size="md" className="text-brand-600" />
        Vídeos ({videos.length})
      </h2>

      <div class="flex flex-col lg:flex-row gap-6">
        <!-- Player panel -->
        <div class="flex-1 min-w-0">
          <div id="player-container">
            {activeVideo && (
              <VideoPlayer
                client:load
                assetId={activeVideo.id}
                courseId={id}
                src={localUrl(activeVideo.localPath!)}
                title={activeVideo.metadata?.name ?? activeVideo.id}
                subtitleSrc={subtitleUrl(activeVideo.localPath!)}
                initialTime={videoProgressMap.get(activeVideo.id)?.position ?? 0}
                initialDuration={activeVideo.metadata?.duration ?? 0}
                progressUrl={API_ROUTES.PROGRESS.VIDEO}
              />
            )}
          </div>
          <p id="player-title" class="text-sm font-medium mt-3 text-text-primary">
            {activeVideo?.metadata?.name ?? ''}
          </p>
        </div>

        <!-- Video list -->
        <div
          class="lg:w-80 xl:w-96 flex flex-col rounded-xl bg-surface-800 border border-border-subtle shadow-custom max-h-[500px] overflow-hidden"
        >
          <div class="p-3 border-b flex items-center justify-between bg-surface-800/50 backdrop-blur-sm border-border-subtle shrink-0">
            <div class="text-2xs font-bold uppercase tracking-widest text-text-muted">
              Contenido del curso
            </div>
            <!-- Autoplay Toggle -->
            <label class="flex items-center gap-2 cursor-pointer group">
              <span class="text-[10px] font-bold text-text-muted group-hover:text-brand-500 transition-colors uppercase tracking-tight">Autoplay</span>
              <div class="relative inline-flex items-center">
                <input type="checkbox" id="autoplay-toggle" class="sr-only peer">
                <div class="w-7 h-4 bg-surface-600 rounded-full peer peer-checked:bg-brand-600 transition-colors"></div>
                <div class="absolute left-0.5 top-0.5 w-3 h-3 bg-white rounded-full transition-transform peer-checked:translate-x-3"></div>
              </div>
            </label>
          </div>
          <div class="overflow-y-auto flex-1 custom-scrollbar">
            {videos.map((v, i) => {
              const vp = videoProgressMap.get(v.id);
              const isDone = vp?.completed;
              const isActive = v.id === activeVideo?.id;
              
              // Duration logic: use metadata only
              const vDuration = v.metadata?.duration || 0;
              const vPosition = vp?.position || 0;
              const vProgressPercent = vDuration > 0 ? Math.min(100, Math.round((vPosition / vDuration) * 100)) : 0;
              
              const formatTime = (sec: number) => {
                const m = Math.floor(sec / 60);
                const s = Math.floor(sec % 60);
                return `${m}:${String(s).padStart(2, '0')}`;
              };

              return (
                <button
                  class={`video-item w-full text-left flex items-center gap-4 p-4 transition-all hover:bg-surface-900 border-b border-border-subtle last:border-b-0 cursor-pointer group ${
                    isActive ? 'bg-surface-700/50' : 'bg-transparent'
                  }`}
                  data-src={localUrl(v.localPath!)}
                  data-asset-id={v.id}
                  data-title={v.metadata?.name ?? v.id}
                  data-subtitle={subtitleUrl(v.localPath!)}
                  data-position={vp?.position ?? 0}
                >
                  {/* Progress Ring */}
                  <div class="relative shrink-0 w-9 h-9 flex items-center justify-center">
                    <svg class="w-full h-full -rotate-90 transform" viewBox="0 0 36 36">
                      {/* Background circle */}
                      <circle
                        class="text-surface-600 stroke-current"
                        stroke-width="3"
                        fill="transparent"
                        r="16"
                        cx="18"
                        cy="18"
                      />
                      {/* Progress circle */}
                      <circle
                        class:list={[
                          "transition-all duration-500 stroke-current",
                          isDone ? "text-brand-500" : "text-brand-600"
                        ]}
                        stroke-width="3"
                        stroke-dasharray="100, 100"
                        stroke-dashoffset={100 - vProgressPercent}
                        stroke-linecap="round"
                        fill="transparent"
                        r="16"
                        cx="18"
                        cy="18"
                      />
                    </svg>
                    <div class="absolute inset-0 flex items-center justify-center text-[10px] font-bold text-text-secondary group-hover:text-brand-400 transition-colors">
                      {isDone ? (
                        <Icon name="check" size="xs" className="text-brand-500" />
                      ) : (
                        <span>{i + 1}</span>
                      )}
                    </div>
                  </div>

                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-2 mb-0.5">
                      <p class={`text-xs leading-tight line-clamp-1 transition-colors ${isActive ? 'text-text-primary font-bold' : 'text-text-secondary font-medium group-hover:text-text-primary'}`}>
                        {v.metadata?.name ?? `Vídeo ${i + 1}`}
                      </p>
                      {vDuration > 0 && (
                        <span class="text-[10px] font-mono text-text-muted shrink-0 bg-surface-900/50 px-1.5 py-0.5 rounded">
                          {formatTime(vDuration)}
                        </span>
                      )}
                    </div>
                    {vp && !vp.completed && vp.position > 2 && (
                      <div class="flex items-center gap-1.5">
                         <div class="flex-1 h-1 bg-surface-900 rounded-full overflow-hidden">
                           <div class="h-full bg-brand-600/50" style={`width: ${vProgressPercent}%`} />
                         </div>
                         <span class="text-[9px] font-bold text-brand-600/80 uppercase tracking-tighter shrink-0">
                           {vProgressPercent}%
                         </span>
                      </div>
                    )}
                  </div>
                </button>
              );
            })}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ─── Guides ──────────────────────────────────────────────────────── -->
  {guides.length > 0 && (
    <section class="mb-10">
      <h2 class="section-title mb-5">
        <Icon name="file-text" size="md" className="text-brand-600" />
        Guías ({guides.length})
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {guides.map((g, i) => (
          <GuideCard
            assetId={g.id}
            courseId={id}
            name={g.metadata?.name ?? g.metadata?.filename ?? `Guía ${i + 1}`}
            localUrl={localUrl(g.localPath!)}
            progress={guideProgressMap.get(g.id)}
            totalPages={g.metadata?.totalPages}
          />
        ))}
      </div>
    </section>
  )}

  {videos.length === 0 && guides.length === 0 && (
    <div class="text-center py-24 rounded-2xl bg-surface-900 border border-dashed border-border-subtle">
      <div class="flex justify-center mb-4">
        <div class="w-16 h-16 rounded-full bg-surface-800 flex items-center justify-center text-text-muted">
          <Icon name="inbox" size="xl" />
        </div>
      </div>
      <p class="font-medium text-sm text-text-secondary">Sin assets descargados para este curso.</p>
    </div>
  )}
  </div>
</Layout>

<script>
  import { apiClient } from "../../platform/api/client";

  const context = document.getElementById('course-page-context') as HTMLElement;
  const COURSE_PROGRESS_URL = context.dataset.progressUrl!;
  const METADATA_URL = context.dataset.metadataUrl!;

  // ─── Video playlist switching ────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.video-item').forEach(btn => {
    btn.addEventListener('click', () => {
      const assetId = btn.dataset.assetId!;
      const url = new URL(window.location.href);
      url.searchParams.set('v', assetId);
      window.location.href = url.toString();
    });
  });

  // ─── Mark complete button ─────────────────────────────────────────────
  const btnComplete = document.getElementById('btn-complete') as HTMLButtonElement | null;
  btnComplete?.addEventListener('click', async () => {
    const courseId = btnComplete.dataset.courseId!;
    const isCompleted = btnComplete.dataset.completed === 'true';
    const newStatus = isCompleted ? 'in_progress' : 'completed';

    try {
      await apiClient.post(COURSE_PROGRESS_URL, { courseId, status: newStatus });
      window.location.reload();
    } catch (err) {
      console.error('Failed to update course progress:', err);
    }
  });

  // ─── Real-time Progress Updates ──────────────────────────────────────────
  window.addEventListener('video-progress', (e: any) => {
    const { assetId, position, completed } = e.detail;
    const btn = document.querySelector(`.video-item[data-asset-id="${assetId}"]`);
    if (!btn) return;

    // Update data attribute
    btn.setAttribute('data-position', position.toString());

    // Update SVG progress ring
    const videoItem = btn as HTMLElement;
    const durationAttr = videoItem.querySelector('span.font-mono')?.textContent || '0:00';
    const [m, s] = durationAttr.split(':').map(Number);
    const duration = m * 60 + s;

    if (duration > 0) {
      const progressPercent = Math.min(100, Math.round((position / duration) * 100));
      const progressCircle = videoItem.querySelector('circle.stroke-current:last-child') as SVGCircleElement;
      if (progressCircle) {
        progressCircle.style.strokeDashoffset = (100 - progressPercent).toString();
      }

      // Update percentage bar
      const bar = videoItem.querySelector('.bg-brand-600\\/50') as HTMLElement;
      const barText = videoItem.querySelector('span.text-brand-600\\/80') as HTMLElement;
      if (bar) bar.style.width = `${progressPercent}%`;
      if (barText) barText.textContent = `${progressPercent}%`;
    }

    // Update icon if completed
    if (completed) {
      const iconContainer = videoItem.querySelector('.absolute.inset-0.flex.items-center.justify-center') as HTMLElement;
      if (iconContainer && !iconContainer.querySelector('svg[data-icon="check"]')) {
        iconContainer.innerHTML = '<svg class="w-3 h-3 text-brand-500" data-icon="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
      }
    }
  });

  // ─── Autoplay Orchestration ──────────────────────────────────────────────
  const autoplayToggle = document.getElementById('autoplay-toggle') as HTMLInputElement | null;
  if (autoplayToggle) {
    autoplayToggle.checked = localStorage.getItem('autoplayNext') === 'true';
    autoplayToggle.addEventListener('change', () => {
      localStorage.setItem('autoplayNext', autoplayToggle.checked.toString());
    });
  }

  window.addEventListener('video-ended', (e: any) => {
    const { assetId } = e.detail;
    if (!autoplayToggle?.checked) return;

    const currentBtn = document.querySelector(`.video-item[data-asset-id="${assetId}"]`);
    if (!currentBtn) return;

    const allBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.video-item'));
    const currentIndex = allBtns.indexOf(currentBtn as HTMLButtonElement);
    const nextBtn = allBtns[currentIndex + 1];

    if (nextBtn) {
      const nextAssetId = nextBtn.dataset.assetId!;
      const url = new URL(window.location.href);
      url.searchParams.set('v', nextAssetId);
      window.location.href = url.toString();
    }
  });

  // ─── Metadata Polling ─────────────────────────────────────────────────────
  const missingMetadataCards = document.querySelectorAll<HTMLElement>('[data-missing-metadata="true"]');
  
  if (missingMetadataCards.length > 0) {
    const refreshMetadata = async (card: HTMLElement) => {
      const assetId = card.dataset.assetId;
      try {
        const metadata = await apiClient.get<any>(`${METADATA_URL}?assetId=${assetId}`);
        if (metadata && metadata.totalPages) {
            const statusLabel = card.querySelector('.status-label');
            const isDone = card.dataset.isDone === 'true';
            const currentPage = parseInt(card.dataset.currentPage || '0');
            const totalPages = metadata.totalPages;

            if (statusLabel) {
              if (isDone) {
                statusLabel.textContent = 'Completado';
              } else if (currentPage > 1) {
                statusLabel.textContent = `Página ${currentPage} de ${totalPages}`;
              } else {
                statusLabel.textContent = `Ver guía de ${totalPages} páginas`;
              }
            }
            card.dataset.missingMetadata = 'false';
            return true;
          }
      } catch (e) {
        console.error('Error polling metadata:', e);
      }
      return false;
    };

    const pollAll = async () => {
      const remaining = document.querySelectorAll<HTMLElement>('[data-missing-metadata="true"]');
      if (remaining.length === 0) return;
      
      for (const card of remaining) {
        await refreshMetadata(card);
      }
    };

    // Poll on visibility change (re-focusing the course page after closing the PDF)
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') {
        pollAll();
      }
    });

    // Initial soft polling after returning
    setTimeout(pollAll, 1500);
    setTimeout(pollAll, 4000);
  }
</script>

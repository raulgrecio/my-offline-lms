---
export const prerender = false;

import { APP_ROUTES } from "@platform/router/routes";
import { getAllCourses, getCourseAssets } from "@features/courses";
import { getIsFavorite } from "@features/favorites";
import { getDashboardStatus } from "@features/progress";
import Layout from "@layouts/Layout.astro";
import CourseCard from "@components/CourseCard.astro";
import EmptyState from "@components/EmptyState.astro";
import PageHeader from "@components/PageHeader.astro";
import VisibilityToggle from "@components/VisibilityToggle.astro";

const showAll = Astro.url.searchParams.get("all") !== "false";
const baseUrl = APP_ROUTES.COURSES.INDEX;
const courses = getAllCourses();
const allProgress = getDashboardStatus().allProgress;
const progressMap = new Map(allProgress.map((p) => [p.id, p]));

const coursesWithStats = courses
  .map((c) => {
    const progress = progressMap.get(c.id);
    const assets = getCourseAssets({ courseId: c.id });
    const completedAssets = progress?.completedItems || 0;
    const totalAssets = assets.filter((a) => a.status === "COMPLETED").length;
    const progressPercent = totalAssets > 0 
      ? Math.round((completedAssets / totalAssets) * 100) 
      : 0;

    return {
      ...c,
      status: progress?.status ?? "not_started",
      completedAssets,
      totalAssets,
      progressPercent,
    };
  })
  .filter((c) => showAll || c.totalAssets > 0);
---

<Layout title="Cursos">
  <PageHeader
    title="Cursos"
    icon="book-open"
    subtitle={`${coursesWithStats.length} de ${courses.length} cursos disponibles`}
  >
    <VisibilityToggle
      slot="actions"
      showAll={showAll}
      baseUrl={baseUrl}
      targetIds={["courses-container", "page-header-subtitle"]}
    />
  </PageHeader>

  <div id="courses-container">
    {
      coursesWithStats.length > 0 ? (
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
          {coursesWithStats.map((c) => (
            <CourseCard
              id={c.id}
              title={c.title}
              status={c.status}
              totalAssets={c.totalAssets}
              progress={c.progressPercent}
              isFavorite={getIsFavorite({ id: c.id, type: 'course' })}
            />
          ))}
        </div>
      ) : (
        <EmptyState message="Sin cursos descargados." />
      )
    }
  </div>
</Layout>

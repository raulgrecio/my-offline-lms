---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import CourseCard from "../../components/CourseCard.astro";
import PageHeader from "../../components/PageHeader.astro";
import VisibilityToggle from "../../components/VisibilityToggle.astro";
import EmptyState from "../../components/EmptyState.astro";
import { getAllCourses, getCourseAssets } from "../../features/courses";
import { getAllCourseProgress } from "../../features/progress";

const showAll = Astro.url.searchParams.get("all") !== "false";
const baseUrl = "/courses";
const courses = getAllCourses();
const allProgress = getAllCourseProgress();
const progressMap = new Map(allProgress.map((p) => [p.courseId, p.status]));

const coursesWithStats = courses
  .map((c) => {
    const assets = getCourseAssets(c.id);
    return {
      ...c,
      status: progressMap.get(c.id) ?? "not_started",
      assetCount: assets.filter((a) => a.status === "COMPLETED").length,
    };
  })
  .filter((c) => showAll || c.assetCount > 0);
---

<Layout title="Cursos">
  <PageHeader
    title="Cursos"
    icon="book-open"
    subtitle={`${coursesWithStats.length} de ${courses.length} cursos disponibles`}
  >
    <VisibilityToggle slot="actions" showAll={showAll} baseUrl={baseUrl} />
  </PageHeader>

  {
    coursesWithStats.length > 0 ? (
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
        {coursesWithStats.map((c) => (
          <CourseCard
            id={c.id}
            title={c.title}
            status={c.status}
            assetCount={c.assetCount}
          />
        ))}
      </div>
    ) : (
      <EmptyState message="Sin cursos descargados." />
    )
  }
</Layout>

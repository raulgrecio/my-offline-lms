---
export const prerender = false;

import { APP_ROUTES } from "@web/platform/router/routes";
import { getAllCourses } from "@web/features/courses";
import { getCourseProgress } from "@web/features/progress";
import { getIsFavorite } from "@web/features/favorites";
import Layout from "@web/layouts/MainLayout.astro";
import CourseCard from "@web/ui/components/CourseCard.astro";
import EmptyState from "@web/ui/components/EmptyState/EmptyState.astro";
import PageHeader from "@web/ui/components/PageHeader.astro";
import VisibilityToggle from "@web/ui/primitives/VisibilityToggle.astro";

const showAll = Astro.url.searchParams.get("all") !== "false";
const baseUrl = APP_ROUTES.COURSES.INDEX;

const courses = await getAllCourses();

const coursesWithStatsResults = await Promise.all(
  courses.map(async (c) => {
    const [progress, isFavorite] = await Promise.all([
      getCourseProgress({ id: c.id }),
      getIsFavorite({ id: c.id, type: "course" }),
    ]);

    return {
      ...c,
      status: progress.status,
      totalAssets: progress.totalItems,
      progress: progress.progress,
      isFavorite,
    };
  }),
);

const coursesWithStats = coursesWithStatsResults.filter(
  (c) => showAll || c.totalAssets > 0,
);
const hasContent = coursesWithStats.length > 0;
---

<Layout title="Cursos">
  <PageHeader
    title="Cursos"
    icon="book-open"
    subtitle={`${coursesWithStats.length} de ${courses.length} cursos disponibles`}
  >
    <VisibilityToggle
      slot="actions"
      showAll={showAll}
      baseUrl={baseUrl}
      targetIds={["courses-container", "page-header-subtitle"]}
    />
  </PageHeader>

  <div id="courses-container">
    {
      hasContent ? (
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
          {coursesWithStats.map((c) => (
            <CourseCard
              id={c.id}
              title={c.title}
              status={c.status}
              totalAssets={c.totalAssets}
              progress={c.progress}
              isFavorite={c.isFavorite}
            />
          ))}
        </div>
      ) : (
        <EmptyState message="Sin cursos descargados." />
      )
    }
  </div>
</Layout>

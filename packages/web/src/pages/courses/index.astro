---
export const prerender = false;

import { APP_ROUTES } from "@platform/router/routes";
import { getAllCourses } from "@features/courses";
import { getCourseProgress } from "@features/progress";
import { getIsFavorite } from "@features/favorites";
import Layout from "@layouts/Layout.astro";
import CourseCard from "@components/CourseCard.astro";
import EmptyState from "@components/EmptyState.astro";
import PageHeader from "@components/PageHeader.astro";
import VisibilityToggle from "@components/VisibilityToggle.astro";

const showAll = Astro.url.searchParams.get("all") !== "false";
const baseUrl = APP_ROUTES.COURSES.INDEX;

const courses = await getAllCourses();

const coursesWithStatsResults = await Promise.all(
  courses.map(async (c) => {
    const progress = await getCourseProgress({ id: c.id });
    const isFavorite = await getIsFavorite({ id: c.id, type: "course" });
    
    return {
      ...c,
      status: progress.status,
      totalAssets: progress.totalItems,
      progress: progress.progress,
      isFavorite,
    };
  })
);

const coursesWithStats = coursesWithStatsResults.filter((c) => showAll || c.totalAssets > 0);
---

<Layout title="Cursos">
  <PageHeader
    title="Cursos"
    icon="book-open"
    subtitle={`${coursesWithStats.length} de ${courses.length} cursos disponibles`}
  >
    <VisibilityToggle
      slot="actions"
      showAll={showAll}
      baseUrl={baseUrl}
      targetIds={["courses-container", "page-header-subtitle"]}
    />
  </PageHeader>

  <div id="courses-container">
    {
      coursesWithStats.length > 0 ? (
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
          {coursesWithStats.map((c) => (
            <CourseCard
              id={c.id}
              title={c.title}
              status={c.status}
              totalAssets={c.totalAssets}
              progress={c.progress}
              isFavorite={c.isFavorite}
            />
          ))}
        </div>
      ) : (
        <EmptyState message="Sin cursos descargados." />
      )
    }
  </div>
</Layout>

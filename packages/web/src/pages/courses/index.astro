---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import CourseCard from "../../components/CourseCard.astro";
import { Icon } from "../../components/Icon";
import { getAllCourses, getCourseAssets } from "../../features/courses";
import { getAllCourseProgress } from "../../features/progress";

const courses = getAllCourses();
const allProgress = getAllCourseProgress();
const progressMap = new Map(allProgress.map((p) => [p.courseId, p.status]));

const coursesWithStats = courses.map((c) => {
  const assets = getCourseAssets(c.id);
  return {
    ...c,
    status: progressMap.get(c.id) ?? "not_started",
    assetCount: assets.filter((a) => a.status === "COMPLETED").length,
  };
});
---

<Layout title="Cursos">
  <div class="mb-8 flex items-end justify-between">
    <div>
      <h1
        class="text-2xl sm:text-3xl font-bold mb-1 flex items-center gap-2 text-text-primary"
      >
        <Icon
          name="book-open"
          size="lg"
          className="text-brand-600"
        />
        Cursos
      </h1>
      <p class="text-sm text-text-secondary">
        {courses.length} cursos disponibles
      </p>
    </div>
  </div>

  {
    coursesWithStats.length > 0 ? (
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
        {coursesWithStats.map((c) => (
          <CourseCard
            id={c.id}
            title={c.title}
            status={c.status}
            assetCount={c.assetCount}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-24 rounded-2xl bg-[var(--bg-secondary)] border border-dashed border-[var(--border-subtle)]">
        <div class="flex justify-center mb-4">
          <div
            class="w-16 h-16 rounded-full bg-surface-800 flex items-center justify-center text-text-muted"
          >
            <Icon name="inbox" size="xl" />
          </div>
        </div>
        <p class="font-medium text-text-secondary">
          Sin cursos descargados.
        </p>
      </div>
    )
  }
</Layout>

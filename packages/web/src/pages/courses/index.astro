---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import CourseCard from "../../components/CourseCard.astro";
import {
  getAllCourses,
  getCourseAssets,
} from "../../features/courses";
import {
  getAllCourseProgress,
} from "../../features/progress";

const courses = getAllCourses();
const allProgress = getAllCourseProgress();
const progressMap = new Map(allProgress.map((p) => [p.courseId, p.status]));

const coursesWithStats = courses.map((c) => {
  const assets = getCourseAssets(c.id);
  return {
    ...c,
    status: progressMap.get(c.id) ?? "not_started",
    assetCount: assets.filter((a) => a.status === "COMPLETED").length,
  };
});
---

<Layout title="Cursos">
  <div class="mb-8">
    <h1
      class="text-2xl sm:text-3xl font-bold mb-1"
      style="color: var(--color-text-primary);"
    >
      📚 Cursos
    </h1>
    <p class="text-sm" style="color: var(--color-text-secondary);">
      {courses.length} cursos disponibles
    </p>
  </div>

  {
    coursesWithStats.length > 0 ? (
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
        {coursesWithStats.map((c) => (
          <CourseCard
            id={c.id}
            title={c.title}
            status={c.status}
            assetCount={c.assetCount}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-24">
        <div class="text-5xl mb-4">📭</div>
        <p style="color: var(--color-text-secondary);">
          Sin cursos descargados.
        </p>
      </div>
    )
  }
</Layout>

---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import CourseCard from "../../components/CourseCard.astro";
import PageHeader from "../../components/PageHeader.astro";
import VisibilityToggle from "../../components/VisibilityToggle.astro";
import EmptyState from "../../components/EmptyState.astro";
import { getAllCourses, getCourseAssets } from "../../features/courses";
import { getAllCourseProgress } from "../../features/progress";

const showAll = Astro.url.searchParams.get("all") !== "false";
const baseUrl = "/courses";
const courses = getAllCourses();
const allProgress = getAllCourseProgress();
const progressMap = new Map(allProgress.map((p) => [p.courseId, p]));

const coursesWithStats = courses
  .map((c) => {
    const progress = progressMap.get(c.id);
    const assets = getCourseAssets(c.id);
    const completedAssets = progress?.completedAssets || 0;
    const totalAssets = assets.filter((a) => a.status === "COMPLETED").length;
    const progressPercent = totalAssets > 0 
      ? Math.round((completedAssets / totalAssets) * 100) 
      : 0;

    return {
      ...c,
      status: progress?.status ?? "not_started",
      completedAssets,
      totalAssets,
      progressPercent,
    };
  })
  .filter((c) => showAll || c.totalAssets > 0);
---

<Layout title="Cursos">
  <PageHeader
    title="Cursos"
    icon="book-open"
    subtitle={`${coursesWithStats.length} de ${courses.length} cursos disponibles`}
  >
    <VisibilityToggle
      slot="actions"
      showAll={showAll}
      baseUrl={baseUrl}
      targetIds={["courses-container", "page-header-subtitle"]}
    />
  </PageHeader>

  <div id="courses-container">
    {
      coursesWithStats.length > 0 ? (
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
          {coursesWithStats.map((c) => (
            <CourseCard
              id={c.id}
              title={c.title}
              status={c.status}
              totalAssets={c.totalAssets}
              progress={c.progressPercent}
            />
          ))}
        </div>
      ) : (
        <EmptyState message="Sin cursos descargados." />
      )
    }
  </div>
</Layout>

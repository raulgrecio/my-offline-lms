---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import CourseCard from "../../components/CourseCard.astro";
import ProgressBadge from "../../components/ProgressBadge.astro";
import ProgressBar from "../../components/ProgreesBar.astro";
import { Icon } from "../../components/Icon";
import {
  getLearningPathById,
  getCoursesForPath,
} from "../../features/learning-paths";
import { getAllCourseProgress, getLearningPathProgress } from "../../features/progress";
import { setActiveLearningPath } from "../../features/settings";
import { APP_ROUTES } from "../../platform/router/routes";


const { id } = Astro.params;
if (!id) return Astro.redirect(APP_ROUTES.LEARNING_PATHS.INDEX);

// Set this as the active LP when visiting
setActiveLearningPath(id);

const path = getLearningPathById(id);
if (!path) return Astro.redirect(APP_ROUTES.LEARNING_PATHS.INDEX);

const courses = getCoursesForPath(id);
const lpProgress = getLearningPathProgress(id);
const allProgress = getAllCourseProgress();
const progressMap = new Map(allProgress.map((p) => [p.courseId, p]));

const completedCount = lpProgress?.completedCourses || 0;
const progress = lpProgress?.progress || 0;
---

<Layout title={path.title} description={path.description}>
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-xs mb-6 text-text-muted">
    <a href={APP_ROUTES.HOME} class="text-text-muted no-underline hover:underline">Inicio</a>
    <Icon name="chevron-right" size="xs" />
    <a href={APP_ROUTES.LEARNING_PATHS.INDEX} class="text-text-muted no-underline hover:underline">Learning Paths</a>
    <Icon name="chevron-right" size="xs" />
    <span class="text-text-secondary">{path.title}</span>
  </nav>

  <!-- Header -->
  <div class="mb-8">
    <div class="flex items-start gap-4 mb-4">
      <div
        class="shrink-0 w-14 h-14 rounded-2xl flex items-center justify-center text-white bg-brand-600 shadow-brand"
      >
        <Icon name="graduation-cap" size="lg" strokeWidth={2.5} />
      </div>
      <div class="flex-1 min-w-0">
        <h1
          class="text-xl sm:text-2xl font-bold leading-snug mb-2 text-text-primary"
        >
          {path.title}
        </h1>
        <ProgressBadge
          status={completedCount === courses.length && courses.length > 0
            ? "completed"
            : completedCount > 0
            ? "in_progress"
            : "not_started"}
        />
      </div>
    </div>

    {
      path.description && (
        <div
          class="prose mb-6"
          set:html={path.description}
        />
      )
    }

    <!-- Progress summary -->
    <div
      class="rounded-lg p-4 bg-surface-800 border border-border-default"
    >
      <div class="flex items-center justify-between mb-2 border-none">
        <span
          class="text-sm font-medium text-text-secondary"
        >
          Progreso del learning path
        </span>
        <span class="text-sm font-bold text-brand-400">
          {completedCount} / {courses.length} cursos
        </span>
      </div>
      <ProgressBar progress={progress} />
      <div
        class="text-right text-xs mt-1 text-text-muted"
      >
        {progress}% completado
      </div>
    </div>
  </div>

  <hr class="divider mb-8" />

  <!-- Course list -->
  <div>
    <h2 class="section-title mb-5">
      <Icon
        name="book-open"
        size="md"
        className="text-brand-600"
      />
      Cursos del path ({courses.length})
    </h2>
    {
      courses.length > 0 ? (
        <div class="flex flex-col gap-3">
          {courses.map((course) => {
            const progressObj = progressMap.get(course.id);
            const progressPercent = progressObj?.totalAssets && progressObj.totalAssets > 0
              ? Math.round((progressObj.completedAssets / progressObj.totalAssets) * 100)
              : 0;
            return (
              <CourseCard
                id={course.id}
                title={course.title}
                status={progressObj?.status ?? "not_started"}
                totalAssets={progressObj?.totalAssets}
                progress={progressPercent}
                orderIndex={course.orderIndex}
              />
            );
          })}
        </div>
      ) : (
        <p class="text-text-muted">
          Sin cursos asignados a este path.
        </p>
      )
    }
  </div>
</Layout>

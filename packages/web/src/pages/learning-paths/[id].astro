---
export const prerender = false;

import { APP_ROUTES } from "@web/platform/router/routes";
import { getLearningPathDetails } from "@web/features/learning-paths";
import {
  getCourseProgress,
  getLearningPathProgress,
} from "@web/features/progress";
import { getIsFavorite } from "@web/features/favorites";
import Layout from "@web/layouts/MainLayout.astro";
import { Icon } from "@web/ui/primitives/Icon";
import ProgressBar from "@web/ui/primitives/ProgressBar.astro";
import CourseCard from "@web/ui/components/CourseCard.astro";
import EmptyState from "@web/ui/components/EmptyState/EmptyState.astro";
import FavoriteButton from "@web/ui/components/FavoriteButton.astro";
import PageHeader from "@web/ui/components/PageHeader.astro";
import SectionHeader from "@web/ui/components/SectionHeader.astro";

interface PathPageProps {
  id?: string;
}

const { id } = Astro.params as PathPageProps;
if (!id) return Astro.redirect(APP_ROUTES.LEARNING_PATHS.INDEX);

const pathDetails = await getLearningPathDetails({ id });
if (!pathDetails) return Astro.redirect(APP_ROUTES.LEARNING_PATHS.INDEX);

const { path, courses } = pathDetails;

const [lpProgress, isFavorite] = await Promise.all([
  getLearningPathProgress({ id: path.id }),
  getIsFavorite({ id, type: "learning-path" }),
]);

const courseData = await Promise.all(
  courses.map(async (course) => {
    const [progress, isFavorite] = await Promise.all([
      getCourseProgress({ id: course.id }),
      getIsFavorite({ id: course.id, type: "course" }),
    ]);

    return {
      ...course,
      progress,
      isFavorite,
    };
  }),
);

const progress = lpProgress.progress;
const completedCount = lpProgress.completedItems;
const status = lpProgress.status;

const hasContent = courseData.length > 0;
---

<Layout title={path.title} description={path.description}>
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-xs mb-6 text-text-muted">
    <a
      href={APP_ROUTES.HOME}
      class="text-text-muted no-underline hover:underline">Inicio</a
    >
    <Icon name="chevron-right" size="xs" />
    <a
      href={APP_ROUTES.LEARNING_PATHS.INDEX}
      class="text-text-muted no-underline hover:underline">Learning Paths</a
    >
    <Icon name="chevron-right" size="xs" />
    <span class="text-text-secondary">{path.title}</span>
  </nav>

  <!-- Header -->
  <PageHeader
    title={path.title}
    icon="graduation-cap"
    status={status}
    subtitle={`${courses.length} cursos`}
  >
    <div slot="actions">
      <FavoriteButton
        id={id}
        type="learning-path"
        isFavorite={isFavorite}
        size="md"
        hoverEffect="translate"
      />
    </div>
    <>
      {
        path.description && (
          <div class="prose mb-6" set:html={path.description} />
        )
      }

      <!-- Progress summary block rendered in the default slot -->

      <!-- Progress summary -->
      <div class="rounded-lg p-4 bg-surface-800 border border-border-default">
        <div class="flex items-center justify-between mb-2 border-none">
          <span class="text-sm font-medium text-text-secondary">
            Progreso del learning path
          </span>
          <span class="text-sm font-bold text-brand-400">
            {completedCount} / {courses.length} cursos
          </span>
        </div>
        <ProgressBar progress={progress} />
        <div class="text-right text-xs mt-1 text-text-muted">
          {progress}% completado
        </div>
      </div>
    </>
  </PageHeader>

  <!-- Course list -->
  <div>
    <SectionHeader
      title={`Cursos del path (${courses.length})`}
      icon="book-open"
    />
    {
      hasContent ? (
        <div class="flex flex-col gap-3">
          {courseData.map((course) => (
            <CourseCard
              id={course.id}
              title={course.title}
              status={course.progress.status}
              totalAssets={course.progress.totalItems}
              progress={course.progress.progress}
              orderIndex={course.orderIndex}
              isFavorite={course.isFavorite}
            />
          ))}
        </div>
      ) : (
        <EmptyState
          message="Sin cursos asignados a este path."
          icon="book-open"
        />
      )
    }
  </div>
</Layout>

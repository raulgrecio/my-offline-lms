---
export const prerender = false;

import { APP_ROUTES } from "@platform/router/routes";
import { getIsFavorite } from "@features/favorites";
import {
  getLearningPathDetails,
  getLearningPathWithStats,
} from "@features/learning-paths";
import { getDashboardStatus } from "@features/progress";
import Layout from "@layouts/Layout.astro";
import CourseCard from "@components/CourseCard.astro";
import { Icon } from "@components/Icon";
import FavoriteButton from "@components/FavoriteButton.astro";
import PageHeader from "@components/PageHeader.astro";
import ProgressBar from "@components/ProgressBar.astro";


interface PathPageProps {
  id?: string;
}

const { id } = Astro.params as PathPageProps;
if (!id) return Astro.redirect(APP_ROUTES.LEARNING_PATHS.INDEX);

const pathDetails = getLearningPathDetails({ id });
if (!pathDetails) return Astro.redirect(APP_ROUTES.LEARNING_PATHS.INDEX);

const { path, courses } = pathDetails;

const lpStats = getLearningPathWithStats({ id: path.id });
const isFavorite = lpStats.isFavorite;
const progress = lpStats.progress;
const completedCount = lpStats.completedCount;
const status = lpStats.status;

const { allProgress } = getDashboardStatus();
const progressMap = new Map(allProgress.map((p) => [p.id, p]));
---

<Layout title={path.title} description={path.description}>
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-xs mb-6 text-text-muted">
    <a href={APP_ROUTES.HOME} class="text-text-muted no-underline hover:underline">Inicio</a>
    <Icon name="chevron-right" size="xs" />
    <a href={APP_ROUTES.LEARNING_PATHS.INDEX} class="text-text-muted no-underline hover:underline">Learning Paths</a>
    <Icon name="chevron-right" size="xs" />
    <span class="text-text-secondary">{path.title}</span>
  </nav>

  <!-- Header -->
  <PageHeader
    title={path.title}
    icon="graduation-cap"
    status={status}
    subtext={`${courses.length} cursos`}
  >
    <div slot="actions">
      <FavoriteButton 
        id={id} 
        type="learning-path" 
        isFavorite={isFavorite} 
        size="lg" 
        hoverEffect="translate" 
      />
    </div>
  </PageHeader>

  {
    path.description && (
      <div
        class="prose mb-6"
        set:html={path.description}
      />
    )
  }

  <!-- Progress summary -->
  <div
    class="rounded-lg p-4 bg-surface-800 border border-border-default"
  >
    <div class="flex items-center justify-between mb-2 border-none">
      <span
        class="text-sm font-medium text-text-secondary"
      >
        Progreso del learning path
      </span>
      <span class="text-sm font-bold text-brand-400">
        {completedCount} / {courses.length} cursos
      </span>
    </div>
    <ProgressBar progress={progress} />
    <div
      class="text-right text-xs mt-1 text-text-muted"
    >
      {progress}% completado
    </div>
  </div>

  <hr class="divider mb-8" />

  <!-- Course list -->
  <div>
    <h2 class="section-title mb-5">
      <Icon
        name="book-open"
        size="md"
        className="text-brand-600"
      />
      Cursos del path ({courses.length})
    </h2>
    {
      courses.length > 0 ? (
        <div class="flex flex-col gap-3">
          {courses.map((course) => {
            const progressObj = progressMap.get(course.id);
            const progressPercent = progressObj?.progress || 0;
            return (
              <CourseCard
                id={course.id}
                title={course.title}
                status={progressObj?.status ?? "not_started"}
                totalAssets={progressObj?.totalItems}
                progress={progressPercent}
                orderIndex={course.orderIndex}
                isFavorite={getIsFavorite({ id: course.id, type: 'course' })}
              />
            );
          })}
        </div>
      ) : (
        <p class="text-text-muted">
          Sin cursos asignados a este path.
        </p>
      )
    }
  </div>
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import LearningPathCard from "../../components/LearningPathCard.astro";
import PageHeader from "../../components/PageHeader.astro";
import VisibilityToggle from "../../components/VisibilityToggle.astro";
import EmptyState from "../../components/EmptyState.astro";
import {
  getAllLearningPaths,
  getCoursesForPath,
} from "../../features/learning-paths";
import { getCourseAssets } from "../../features/courses";
import { getAllCourseProgress } from "../../features/progress";
import { getActiveLearningPath } from "../../features/settings";
import { APP_ROUTES } from "../../platform/router/routes";

const showAll = Astro.url.searchParams.get("all") !== "false";
const baseUrl = APP_ROUTES.LEARNING_PATHS.INDEX;

const learningPaths = getAllLearningPaths();
const allProgress = getAllCourseProgress();
const activePathId = getActiveLearningPath();
const progressMap = new Map(allProgress.map((p) => [p.courseId, p.status]));

const lpStats = learningPaths
  .map((lp) => {
    const lpCourses = getCoursesForPath(lp.id);
    const completed = lpCourses.filter(
      (c) => progressMap.get(c.id) === "completed"
    ).length;

    // Calculate asset count for the path
    const totalAssets = lpCourses.reduce((acc, course) => {
      const assets = getCourseAssets(course.id);
      return acc + assets.filter((a) => a.status === "COMPLETED").length;
    }, 0);

    return {
      ...lp,
      courseCount: lpCourses.length,
      completedCount: completed,
      assetCount: totalAssets,
    };
  })
  .filter((lp) => showAll || lp.assetCount > 0);
---

<Layout title="Learning Paths">
  <PageHeader
    title="Learning Paths"
    icon="layers"
    subtitle={`${lpStats.length} de ${learningPaths.length} paths disponibles`}
  >
    <VisibilityToggle
      slot="actions"
      showAll={showAll}
      baseUrl={baseUrl}
      targetIds={["learning-paths-container", "page-header-subtitle"]}
    />
  </PageHeader>
  
  <div id="learning-paths-container">
    {
      lpStats.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {lpStats.map((lp) => (
            <LearningPathCard
              id={lp.id}
              title={lp.title}
              description={lp.description}
              courseCount={lp.courseCount}
              completedCount={lp.completedCount}
              isActive={lp.id === activePathId}
            />
          ))}
        </div>
      ) : (
        <EmptyState message="Sin learning paths descargados." />
      )
    }
  </div>
</Layout>

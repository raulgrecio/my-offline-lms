---
import { APP_ROUTES } from "@platform/router/routes";
import {
  getAllLearningPaths,
} from "@features/learning-paths";
import { getLearningPathProgress } from "@features/progress";
import { getIsFavorite } from "@features/favorites";
import Layout from "@layouts/Layout.astro";
import EmptyState from "@components/EmptyState.astro";
import LearningPathCard from "@components/LearningPathCard.astro";
import PageHeader from "@components/PageHeader.astro";
import VisibilityToggle from "@components/VisibilityToggle.astro";

const showAll = Astro.url.searchParams.get("all") !== "false";
const baseUrl = APP_ROUTES.LEARNING_PATHS.INDEX;

const learningPaths = getAllLearningPaths();

const lpStats = learningPaths
  .map((lp) => {
    const progress = getLearningPathProgress({ id: lp.id });
    const isFavorite = getIsFavorite({ id: lp.id, type: "learning-path" });
    return {
      ...lp,
      courseCount: progress.totalItems,
      completedCount: progress.completedItems,
      inProgressCount: progress.inProgressItems,
      progress: progress.progress,
      status: progress.status,
      isFavorite,
    };
  })
  .filter((stats) => showAll || stats.courseCount > 0);
---

<Layout title="Learning Paths">
  <PageHeader
    title="Learning Paths"
    icon="layers"
    subtitle={`${lpStats.length} de ${learningPaths.length} paths disponibles`}
  >
    <VisibilityToggle
      slot="actions"
      showAll={showAll}
      baseUrl={baseUrl}
      targetIds={["learning-paths-container", "page-header-subtitle"]}
    />
  </PageHeader>
  
  <div id="learning-paths-container">
    {
      lpStats.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {lpStats.map((lp) => (
            <LearningPathCard
              id={lp.id}
              title={lp.title}
              description={lp.description}
              courseCount={lp.courseCount}
              completedCount={lp.completedCount}
              inProgressCount={lp.inProgressCount}
              progress={lp.progress}
              status={lp.status}
              isFavorite={lp.isFavorite}
            />
          ))}
        </div>
      ) : (
        <EmptyState message="Sin learning paths descargados." />
      )
    }
  </div>
</Layout>

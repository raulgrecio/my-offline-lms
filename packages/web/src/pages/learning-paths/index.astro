---
import { APP_ROUTES } from "@web/platform/router/routes";
import { getAllLearningPaths } from "@web/features/learning-paths";
import { getLearningPathProgress } from "@web/features/progress";
import { getIsFavorite } from "@web/features/favorites";
import Layout from "@web/layouts/Layout.astro";
import EmptyState from "@web/components/EmptyState/EmptyState.astro";
import LearningPathCard from "@web/components/LearningPathCard.astro";
import PageHeader from "@web/components/PageHeader.astro";
import VisibilityToggle from "@web/components/VisibilityToggle.astro";

const showAll = Astro.url.searchParams.get("all") !== "false";
const baseUrl = APP_ROUTES.LEARNING_PATHS.INDEX;

const learningPaths = await getAllLearningPaths();

const lpStatsResults = await Promise.all(
  learningPaths.map(async (lp) => {
    const [progress, isFavorite] = await Promise.all([
      getLearningPathProgress({ id: lp.id }),
      getIsFavorite({ id: lp.id, type: "learning-path" }),
    ]);

    return {
      ...lp,
      courseCount: progress.totalItems,
      completedCount: progress.completedItems,
      inProgressCount: progress.inProgressItems,
      progress: progress.progress,
      status: progress.status,
      isFavorite,
    };
  }),
);

const lpStats = lpStatsResults.filter(
  (stats) => showAll || stats.courseCount > 0,
);
const hasContent = lpStats.length > 0;
---

<Layout title="Learning Paths">
  <PageHeader
    title="Learning Paths"
    icon="layers"
    subtitle={`${lpStats.length} de ${learningPaths.length} paths disponibles`}
  >
    <VisibilityToggle
      slot="actions"
      showAll={showAll}
      baseUrl={baseUrl}
      targetIds={["learning-paths-container", "page-header-subtitle"]}
    />
  </PageHeader>

  <div id="learning-paths-container">
    {
      hasContent ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {lpStats.map((lp) => (
            <LearningPathCard
              id={lp.id}
              title={lp.title}
              description={lp.description}
              courseCount={lp.courseCount}
              completedCount={lp.completedCount}
              inProgressCount={lp.inProgressCount}
              progress={lp.progress}
              status={lp.status}
              isFavorite={lp.isFavorite}
            />
          ))}
        </div>
      ) : (
        <EmptyState message="Sin learning paths descargados." />
      )
    }
  </div>
</Layout>

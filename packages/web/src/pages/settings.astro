---
export const prerender = false;

import {
  AssetPathResolver,
  NodeFileSystem,
  NodePath,
} from "@my-offline-lms/core/filesystem";

import { getAssetConfigPath, getMonorepoRoot } from "@config/paths";
import { API_ROUTES } from "@platform/api/routes";
import { logger } from "@platform/logging";
import Layout from "@layouts/Layout.astro";
import { Icon } from "@components/Icon";
import AssetBadge from "@components/AssetBadge.astro";
import PageHeader from "@components/PageHeader.astro";
import EmptyState from "@components/EmptyState.astro";
import CollapsibleCard from "@components/CollapsibleCard.astro";
import Button from "@components/Button.astro";

const assetPathsUrl = API_ROUTES.SETTINGS.ASSET_PATHS;

let paths: any[] = [];
let error = null;

try {
  const resolver = new AssetPathResolver({
    configPath: await getAssetConfigPath(),
    monorepoRoot: await getMonorepoRoot(),
    fs: new NodeFileSystem(),
    path: new NodePath(),
    logger,
  });
  paths = await resolver.getAvailablePaths();
} catch (err) {
  logger.error("Error loading asset paths:", err);
  error = "No se pudieron cargar las ubicaciones actuales.";
}

const hasPaths = paths.length > 0;
---

<Layout title="Ajustes de Assets">
  <PageHeader
    title="Configuración de Assets"
    icon="settings"
    subtitle="Gestiona las ubicaciones donde el sistema buscará vídeos y guías (PDFs)."
  />

  <div
    id="settings-view"
    class="max-w-4xl mx-auto"
    data-api-url={assetPathsUrl}
  >
    <CollapsibleCard initialOpen={false}>
      <div slot="header" class="flex items-center gap-3">
        <div
          class="w-10 h-10 rounded-xl flex items-center justify-center bg-brand-600/10 text-brand-600 group-hover:scale-110 transition-all duration-300"
        >
          <Icon name="plus" size="md" />
        </div>
        <div>
          <span class="block font-bold text-text-primary leading-tight">
            Añadir nueva ubicación
          </span>
          <span class="block text-[11px] text-text-muted mt-1 leading-tight">
            Configura una nueva carpeta local para tu catálogo de contenidos
          </span>
        </div>
      </div>
      <p class="text-sm text-text-secondary mb-6 leading-relaxed">
        El sistema escaneará estas carpetas para sincronizar la biblioteca de
        vídeos y guías locales. Use rutas absolutas y etiquetas descriptivas.
      </p>

      <form id="add-path-form" class="space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="space-y-1.5">
            <label
              for="label-input"
              class="text-xs font-bold uppercase tracking-wider text-text-muted ml-1"
            >
              Etiqueta identificativa
            </label>
            <input
              type="text"
              id="label-input"
              placeholder="Ej: Disco Externo, NAS..."
              class="w-full px-4 py-2.5 rounded-lg bg-surface-700 border border-border-default outline-none focus:border-brand-500 transition-all text-sm"
              required
            />
          </div>
          <div class="space-y-1.5">
            <label
              for="path-input"
              class="text-xs font-bold uppercase tracking-wider text-text-muted ml-1"
            >
              Ruta absoluta del sistema
            </label>
            <input
              type="text"
              id="path-input"
              placeholder="Ej: /home/usuario/assets"
              class="w-full px-4 py-2.5 rounded-lg bg-surface-700 border border-border-default outline-none focus:border-brand-500 transition-all text-sm"
              required
            />
          </div>
        </div>

        <div class="flex justify-end pt-2">
          <Button type="submit" variant="primary" icon="plus">
            Guardar ubicación
          </Button>
        </div>
      </form>
    </CollapsibleCard>

    <!-- ─── Path List ────────────────────────────────────────────── -->
    <section>
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-text-primary">
          Ubicaciones actuales
        </h2>
      </div>

      <div id="path-list" class="flex flex-col gap-3">
        {
          error ? (
            <div class="py-12 text-center text-red-500 bg-red-500/5 rounded-2xl border border-dashed border-red-500/20">
              <div class="flex justify-center mb-2">
                <Icon name="alert-circle" size="lg" />
              </div>
              <p class="text-sm font-medium">{error}</p>
            </div>
          ) : hasPaths ? (
            paths.map((p) => (
              <div class="card p-4 flex items-center justify-between gap-4 border border-border-subtle bg-surface-800 rounded-2xl">
                <div class="min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <span class="font-bold text-sm text-text-primary">
                      {p.label}
                    </span>
                    {p.available ? (
                      <AssetBadge status="COMPLETED">Conectado</AssetBadge>
                    ) : (
                      <AssetBadge status="FAILED">No disponible</AssetBadge>
                    )}
                  </div>
                  <code class="text-xs break-all text-text-muted">
                    {p.path}
                  </code>
                </div>
                <Button
                  variant="ghost"
                  square
                  muted
                  size="md"
                  icon="trash"
                  class="hover:text-red-400 hover:bg-surface-600"
                  data-action="delete"
                  data-path={p.path}
                  aria-label="Eliminar"
                />
              </div>
            ))
          ) : (
            <EmptyState message="No hay rutas configuradas." icon="inbox" />
          )
        }
      </div>
    </section>
  </div>

  <!-- No logic required here anymore as we use SSR init -->
</Layout>

<script>
  import { apiClient } from "../platform/api/client";

  const settingsView = document.getElementById("settings-view") as HTMLElement;
  const apiUrl = settingsView.dataset.apiUrl!;

  // ─── Delete Paths ────────────────────────────────────────────────────────
  const deleteButtons = document.querySelectorAll('[data-action="delete"]');
  deleteButtons.forEach((btn) => {
    btn.addEventListener("click", async () => {
      const path = (btn as HTMLElement).dataset.path;
      if (path && confirm(`¿Seguro que quieres eliminar la ruta: ${path}?`)) {
        try {
          await apiClient.delete(apiUrl, { path });
          window.location.reload();
        } catch (err) {
          alert(
            `Error al eliminar: ${
              err instanceof Error ? err.message : String(err)
            }`
          );
        }
      }
    });
  });

  // ─── Add Path Form ───────────────────────────────────────────────────────
  const form = document.getElementById("add-path-form") as HTMLFormElement;
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const pathInput = document.getElementById("path-input") as HTMLInputElement;
    const labelInput = document.getElementById(
      "label-input"
    ) as HTMLInputElement;

    try {
      await apiClient.post(apiUrl, {
        path: pathInput.value.trim(),
        label: labelInput.value.trim(),
      });

      pathInput.value = "";
      labelInput.value = "";
      window.location.reload();
    } catch (err) {
      alert(`Error: ${err instanceof Error ? err.message : String(err)}`);
    }
  });
</script>

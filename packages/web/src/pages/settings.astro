---
import Layout from '../layouts/Layout.astro';

export const prerender = false;
---

<Layout title="Ajustes de Assets">
  <div class="max-w-4xl mx-auto">
    <header class="mb-8">
      <h1 class="text-3xl font-bold mb-2" style="color: var(--color-text-primary);">Configuración de Assets</h1>
      <p style="color: var(--color-text-secondary);">Gestiona las ubicaciones donde el sistema buscará vídeos y guías (PDFs).</p>
    </header>

    <!-- ─── Add New Path ─────────────────────────────────────────── -->
    <section class="card p-6 mb-8">
      <h2 class="text-lg font-semibold mb-4" style="color: var(--color-text-primary);">Añadir nueva ubicación</h2>
      <form id="add-path-form" class="flex flex-col sm:flex-row gap-3">
        <div class="flex-1">
          <input
            type="text"
            id="path-input"
            placeholder="Ej: /mnt/e/oracle-pdfs-videos/assets-new"
            class="w-full px-4 py-2 rounded-lg bg-surface-700 border border-surface-600 outline-none focus:border-oracle-500 transition-colors"
            required
          />
        </div>
        <div class="w-full sm:w-48">
          <input
            type="text"
            id="label-input"
            placeholder="Etiqueta (ej: Disco Externo)"
            class="w-full px-4 py-2 rounded-lg bg-surface-700 border border-surface-600 outline-none focus:border-oracle-500 transition-colors"
            required
          />
        </div>
        <button type="submit" class="btn-primary">Añadir</button>
      </form>
    </section>

    <!-- ─── Path List ────────────────────────────────────────────── -->
    <section>
      <h2 class="text-lg font-semibold mb-4" style="color: var(--color-text-primary);">Ubicaciones actuales</h2>
      <div id="path-list" class="flex flex-col gap-3">
        <div class="animate-pulse flex flex-col gap-3">
          {[1,2,3].map(() => (
            <div class="h-20 rounded-xl bg-surface-800"></div>
          ))}
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .card {
    background-color: var(--color-surface-800);
    border: 1px solid var(--color-surface-700);
    border-radius: 1rem;
  }
  
  input {
    background-color: var(--color-surface-700);
    color: var(--color-text-primary);
  }

  .status-badge {
    padding: 2px 8px;
    border-radius: 9999px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
  }
  
  .status-available {
    background-color: color-mix(in srgb, var(--color-status-completed) 20%, transparent);
    color: var(--color-status-completed);
  }
  
  .status-unavailable {
    background-color: color-mix(in srgb, var(--color-status-failed) 20%, transparent);
    color: var(--color-status-failed);
  }
</style>

<script>
  async function loadPaths() {
    const list = document.getElementById('path-list');
    if (!list) return;

    try {
      const res = await fetch('/api/settings/asset-paths');
      const paths = await res.json();

      if (paths.length === 0) {
        list.innerHTML = `<p class="py-12 text-center text-sm" style="color: var(--color-text-muted);">No hay rutas configuradas.</p>`;
        return;
      }

      list.innerHTML = paths.map((p: any) => `
        <div class="card p-4 flex items-center justify-between gap-4">
          <div class="min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="font-bold text-sm" style="color: var(--color-text-primary);">${p.label}</span>
              <span class="status-badge ${p.available ? 'status-available' : 'status-unavailable'}">
                ${p.available ? '✅ Conectado' : '❌ No disponible'}
              </span>
            </div>
            <code class="text-xs break-all" style="color: var(--color-text-muted);">${p.path}</code>
          </div>
          <button 
            class="btn-delete p-2 rounded-lg hover:bg-surface-600 transition-colors"
            data-path="${p.path}"
          >
            🗑️
          </button>
        </div>
      `).join('');

      // Add delete listeners
      list.querySelectorAll('.btn-delete').forEach(btn => {
        btn.addEventListener('click', async () => {
          const pathToRemove = (btn as HTMLElement).dataset.path;
          if (confirm(`¿Seguro que quieres eliminar la ruta: ${pathToRemove}?`)) {
            const res = await fetch('/api/settings/asset-paths', {
              method: 'DELETE',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ path: pathToRemove })
            });
            if (res.ok) loadPaths();
          }
        });
      });

    } catch (err) {
      list.innerHTML = `<p class="py-12 text-center text-sm text-red-400">Error al cargar las rutas.</p>`;
    }
  }

  // Initial load
  loadPaths();

  // Form handling
  const form = document.getElementById('add-path-form') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const pathInput = document.getElementById('path-input') as HTMLInputElement;
    const labelInput = document.getElementById('label-input') as HTMLInputElement;

    const res = await fetch('/api/settings/asset-paths', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ 
        path: pathInput.value.trim(), 
        label: labelInput.value.trim() 
      })
    });

    if (res.ok) {
      pathInput.value = '';
      labelInput.value = '';
      loadPaths();
    } else {
      const data = await res.json();
      alert(`Error: ${data.error}`);
    }
  });
</script>

---
// @ts-nocheck
import { APP_ROUTES } from "@web/platform/router/routes";
import { getAssetProgress } from "@web/features/progress";
import ViewerLayout from "@web/layouts/ViewerLayout.astro";
import PDFViewer from "@web/components/PDFViewer/Viewer.astro";

const assetId = Astro.url.searchParams.get('assetId');
const courseId = Astro.url.searchParams.get('courseId');
const path = Astro.url.searchParams.get('path');

if (!assetId || !courseId || !path) {
  return Astro.redirect(APP_ROUTES.COURSES.INDEX);
}

const initialProgress = getAssetProgress({ assetId, type: 'guide' });
const initialPage = initialProgress?.position || 1;
---

<ViewerLayout title="Visor de Guía">
  <PDFViewer 
    assetId={assetId} 
    courseId={courseId}
    path={path} 
    initialPage={initialPage} 
  />
</ViewerLayout>

---
export const prerender = false;

import Layout from "@layouts/Layout.astro";
import PageHeader from "@components/PageHeader.astro";
import { ScraperForm } from "@components/scraper/ScraperForm";
import { Icon } from "@components/Icon";
---

<Layout title="Importar Contenido">
  <PageHeader
    title="Centro de Importación"
    icon="download"
    subtitle="Añade nuevos cursos o learning paths a tu biblioteca offline."
  />

  <div class="max-w-2xl mx-auto space-y-10">
    <section class="bg-surface-900 border border-border-subtle rounded-3xl p-8 shadow-2xl relative overflow-hidden group">
      {/* Decorative background element */}
      <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-600/10 rounded-full blur-3xl group-hover:bg-brand-600/20 transition-all duration-700" />
      
      <div class="relative z-10">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-12 rounded-2xl bg-brand-600 flex items-center justify-center text-white shadow-lg shadow-brand-600/30">
            <Icon name="rocket" size="md" />
          </div>
          <div>
            <h2 class="text-xl font-bold text-text-primary">Nueva Sincronización</h2>
            <p class="text-xs text-text-muted mt-1">Ingresa la URL de la plataforma para empezar</p>
          </div>
        </div>

        <ScraperForm client:load />
      </div>
    </section>

    {/* Help Section */}
    <section class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="p-6 rounded-2xl bg-surface-800 border border-border-subtle flex items-start gap-4">
        <div class="p-2 rounded-lg bg-brand-600/10 text-brand-500">
          <Icon name="clock" size="sm" />
        </div>
        <div>
          <h3 class="text-sm font-bold text-text-primary mb-1">Control de Tiempo</h3>
          <p class="text-xs text-text-muted leading-relaxed">
            Las sincronizaciones iniciales pueden tardar unos minutos dependiendo del tamaño del curso.
          </p>
        </div>
      </div>
      <div class="p-6 rounded-2xl bg-surface-800 border border-border-subtle flex items-start gap-4">
        <div class="p-2 rounded-lg bg-green-500/10 text-green-500">
          <Icon name="check-circle" size="sm" />
        </div>
        <div>
          <h3 class="text-sm font-bold text-text-primary mb-1">Descarga Automática</h3>
          <p class="text-xs text-text-muted leading-relaxed">
            Una vez finalizada la sincronización, el contenido aparecerá automáticamente en tu catálogo.
          </p>
        </div>
      </div>
    </section>
  </div>
</Layout>

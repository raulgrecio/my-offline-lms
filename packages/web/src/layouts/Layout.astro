---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle";
import { Icon } from "../components/Icon";
import { APP_ROUTES } from "../platform/router/routes";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Tu plataforma de aprendizaje offline" } =
  Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: APP_ROUTES.HOME, label: "Inicio", icon: "home" },
  { href: APP_ROUTES.LEARNING_PATHS.INDEX, label: "Learning Paths", icon: "layers" },
  { href: APP_ROUTES.COURSES.INDEX, label: "Cursos", icon: "book-open" },
  { href: APP_ROUTES.SETTINGS, label: "Ajustes", icon: "settings" },
] as const;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Offline LMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        const system = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        const theme = saved || system;

        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body 
    class="min-h-screen flex flex-col w-screen overflow-x-hidden"
  >
    <!-- ─── Top Navigation ─────────────────────────────────────────── -->
    <header
      id="main-header"
      class="sticky top-0 z-50 bg-surface-900 border-b border-border-subtle"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a
            href={APP_ROUTES.HOME}
            class="flex items-center gap-2 shrink-0 no-underline"
          >
            <div
              class="w-8 h-8 rounded-lg flex items-center justify-center text-white font-bold text-sm bg-brand-600"
            >
              <span class="rotate-90 inline-block"
                >0</span
              >
            </div>
            <span
              class="font-semibold hidden sm:block text-text-primary"
            >
              Offline LMS
            </span>
          </a>

          <!-- Desktop Nav -->
          <nav class="hidden md:flex items-center gap-1">
            {
              navLinks.map((link) => {
                const isActive = currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href));
                return (
                  <a
                    href={link.href}
                    class={`flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-150 ${
                      isActive 
                        ? "text-brand-400 bg-brand-600/12" 
                        : "text-text-secondary hover:text-text-primary hover:bg-surface-800"
                    }`}
                  >
                    <Icon name={link.icon} size="sm" />
                    {link.label}
                  </a>
                );
              })
            }
          </nav>

          <!-- Mobile hamburger + Toggle -->
          <div class="flex items-center gap-2 md:hidden">
            <ThemeToggle client:load />
            <button
              id="menu-toggle"
              class="p-2 rounded-lg transition-colors hover:bg-surface-700 text-text-secondary"
              aria-label="Abrir menú"
            >
              <div id="icon-menu">
                <Icon name="menu" size="md" />
              </div>
              <div id="icon-close" class="hidden">
                <Icon name="x" size="md" />
              </div>
            </button>
          </div>

          <!-- Desktop Actions -->
          <div class="hidden md:flex items-center gap-3">
            <ThemeToggle client:load />
          </div>
        </div>
      </div>

      <!-- Mobile Nav Drawer -->
      <div
        id="mobile-menu"
        class="hidden md:hidden border-t bg-surface-800 border-border-subtle"
      >
        <nav class="px-4 py-3 flex flex-col gap-1">
          {
            navLinks.map((link) => {
              const isActive = currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href));
              return (
                <a
                  href={link.href}
                  class={`flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all ${
                    isActive 
                      ? "text-brand-400 bg-brand-600/12" 
                      : "text-text-secondary hover:bg-surface-700"
                  }`}
                >
                  <Icon name={link.icon} size="md" />
                  {link.label}
                </a>
              );
            })
          }
        </nav>
      </div>
    </header>

    <!-- ─── Main Content ───────────────────────────────────────────── -->
    <main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8">
      <slot />
    </main>

    <!-- ─── Footer ─────────────────────────────────────────────────── -->
    <footer
      class="mt-auto py-6 text-center text-xs text-text-muted border-t border-border-subtle"
    >
      Offline LMS — contenido descargado y exclusivo para fines educativos y
      personales
    </footer>

    <!-- ─── Mobile Menu Script ─────────────────────────────────────── -->
    <script>
      const toggle = document.getElementById("menu-toggle");
      const menu = document.getElementById("mobile-menu");
      const iconMenu = document.getElementById("icon-menu");
      const iconClose = document.getElementById("icon-close");

      toggle?.addEventListener("click", () => {
        const isOpen = !menu?.classList.contains("hidden");
        menu?.classList.toggle("hidden", isOpen);
        iconMenu?.classList.toggle("hidden", !isOpen);
        iconClose?.classList.toggle("hidden", isOpen);
      });
    </script>
  </body>
</html>

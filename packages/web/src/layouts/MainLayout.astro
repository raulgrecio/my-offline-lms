---
import { ClientRouter } from "astro:transitions";

import { APP_ROUTES } from "@web/platform/router/routes";
import Button from "@web/ui/components/Button/Button.astro";
import Navigation from "@web/ui/patterns/layout/Navigation.astro";
import ThemeToggle from "@web/ui/components/ThemeToggle/ThemeToggle.astro";
import { Icon } from "@web/ui/primitives/Icon";

import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Tu plataforma de aprendizaje offline" } =
  Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: APP_ROUTES.HOME, label: "Inicio", icon: "home" },
  {
    href: APP_ROUTES.LEARNING_PATHS.INDEX,
    label: "Learning Paths",
    icon: "layers",
  },
  { href: APP_ROUTES.COURSES.INDEX, label: "Cursos", icon: "book-open" },
  { href: APP_ROUTES.IMPORT, label: "Importar", icon: "download" },
  { href: APP_ROUTES.SETTINGS, label: "Ajustes", icon: "settings" },
] as const;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Offline LMS</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      (function () {
        const saved = localStorage.getItem("theme");
        const system = window.matchMedia("(prefers-color-scheme: light)")
          .matches
          ? "light"
          : "dark";
        const theme = saved || system;

        document.documentElement.setAttribute("data-theme", theme);
      })();

      // Re-aplicar tema tras navegar (para ClientRouter)
      document.addEventListener("astro:after-swap", () => {
        const theme =
          localStorage.getItem("theme") ||
          (window.matchMedia("(prefers-color-scheme: light)").matches
            ? "light"
            : "dark");
        document.documentElement.setAttribute("data-theme", theme);
      });
    </script>
    <ClientRouter />
  </head>
  <body class="h-screen flex flex-col w-full m-0 p-0 overflow-hidden">
    <!-- ─── Top Navigation ─────────────────────────────────────────── -->
    <header
      id="main-header"
      class="w-full sticky top-0 z-50 bg-surface-900 border-b border-border-subtle"
      transition:name="main-header"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a
            href={APP_ROUTES.HOME}
            class="flex items-center gap-2 shrink-0 no-underline"
          >
            <div
              class="w-8 h-8 rounded-lg flex items-center justify-center text-white font-bold text-sm bg-brand-600"
            >
              <span class="rotate-90 inline-block">0</span>
            </div>
            <span class="font-semibold hidden sm:block text-text-primary">
              Offline LMS
            </span>
          </a>

          <!-- Desktop Nav -->
          <div class="hidden md:flex">
            <Navigation links={navLinks} currentPath={currentPath} />
          </div>

          <!-- Mobile hamburger + Toggle -->
          <div class="flex items-center gap-2 md:hidden">
            <ThemeToggle />
            <Button
              id="menu-toggle"
              variant="ghost"
              size="sm"
              square
              class="text-text-secondary"
              aria-label="Toggle menu"
            >
              <div id="icon-menu">
                <Icon name="menu" size="md" />
              </div>
              <div id="icon-close" class="hidden">
                <Icon name="x" size="md" />
              </div>
            </Button>
          </div>

          <!-- Desktop Actions -->
          <div class="hidden md:flex items-center gap-3">
            <ThemeToggle />
          </div>
        </div>
      </div>

      <!-- Mobile Nav Drawer -->
      <div
        id="mobile-menu"
        class="hidden md:hidden border-t bg-surface-800 border-border-subtle"
      >
        <div class="px-4 py-3">
          <Navigation
            links={navLinks}
            currentPath={currentPath}
            orientation="vertical"
          />
        </div>
      </div>
    </header>

    <div id="scroll-container" class="flex-1 overflow-y-auto">
      <!-- ─── Main Content ───────────────────────────────────────────── -->
      <main class="flex-1 max-w-5xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8">
        <slot />
      </main>

      <!-- ─── Footer ─────────────────────────────────────────────────── -->
      <footer
        class="mt-auto py-6 text-center text-xs text-text-muted border-t border-border-subtle"
      >
        Offline LMS — contenido descargado y exclusivo para fines educativos y
        personales
      </footer>
    </div>

    <!-- ─── Mobile Menu Script ─────────────────────────────────────── -->
    <script>
      const toggle = document.getElementById("menu-toggle");
      const menu = document.getElementById("mobile-menu");
      const iconMenu = document.getElementById("icon-menu");
      const iconClose = document.getElementById("icon-close");

      toggle?.addEventListener("click", () => {
        const isOpen = !menu?.classList.contains("hidden");
        menu?.classList.toggle("hidden", isOpen);
        iconMenu?.classList.toggle("hidden", !isOpen);
        iconClose?.classList.toggle("hidden", isOpen);
      });

      // Asegurar que el scroll vuelva arriba al navegar
      document.addEventListener("astro:after-swap", () => {
        const scroller = document.getElementById("scroll-container");
        if (scroller) scroller.scrollTop = 0;
      });
    </script>
  </body>
</html>

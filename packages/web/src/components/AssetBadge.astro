---
import type { AssetStatus } from "@core/domain";
import Badge, { type BadgeProps, type BadgeConfig } from "./Badge.astro";

interface Props extends BadgeProps {
  status: AssetStatus;
}

const config: Record<AssetStatus, BadgeConfig> = {
  COMPLETED: {
    classes:
      "bg-status-completed/15 text-status-completed border-status-completed/30",
    dotClasses: "bg-status-completed",
    label: "Completado",
  },
  DOWNLOADING: {
    classes:
      "bg-status-downloading/15 text-status-downloading border-status-downloading/30",
    label: "Descargando",
    pulse: true,
  },
  FAILED: {
    classes: "bg-status-failed/15 text-status-failed border-status-failed/30",
    label: "Error",
  },
  PENDING: {
    classes:
      "bg-status-not-started/15 text-status-not-started border-status-not-started/30",
    dotClasses: "bg-transparent border-[1.5px] border-currentColor",
    label: "Pendiente",
  },
};

const { status, className = "", ...rest } = Astro.props;
const normalized = (status?.toUpperCase() || "PENDING") as AssetStatus;
const safeStatus = config[normalized] ? normalized : "PENDING";
const cfg = config[safeStatus] ?? config["PENDING"];
---

<Badge
  {...rest}
  className={`${cfg.classes} ${className}`}
  pulse={rest.pulse ?? cfg.pulse}
  dot={cfg.dotClasses ? "static" : "none"}
  dotClasses={cfg.dotClasses}
  dataStatus={safeStatus}
  ariaLabel={`Estado Asset: ${cfg.label}`}
>
  {
    (normalized === "FAILED" || normalized === "DOWNLOADING") && (
      <Fragment slot="dot">
        {normalized === "FAILED" && (
          <svg
            width="8"
            height="8"
            viewBox="0 0 8 8"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            class="shrink-0"
            aria-hidden="true"
          >
            <path
              d="M1 1L7 7M7 1L1 7"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
            />
          </svg>
        )}

        {normalized === "DOWNLOADING" && (
          <span class="w-1.5 h-1.5 block rounded-full border-[1.5px] border-currentColor border-r-transparent animate-spin shrink-0" />
        )}
      </Fragment>
    )
  }

  <slot>{cfg.label}</slot>
</Badge>

---
import { APP_ROUTES } from "@platform/router/routes";
import type { ProgressStatus } from "@features/progress/domain/model/ProgressStatus";
import { Icon } from "./Icon";
import FavoriteButton from "./FavoriteButton.astro";
import ProgressBadge from "./ProgressBadge.astro";
import ProgressBar from "./ProgreesBar.astro";

interface LearningPathCardProps {
  id: string;
  title: string;
  description: string;
  courseCount: number;
  completedCount?: number;
  isFavorite?: boolean;
  progress?: number;
  status?: ProgressStatus;
}

const {
  id,
  title,
  description,
  courseCount,
  completedCount = 0,
  isFavorite = false,
  progress = 0,
  status = "not_started",
} = Astro.props as LearningPathCardProps;

---

<a
  href={APP_ROUTES.LEARNING_PATHS.DETAIL(id)}
  class="card block p-5 group no-underline relative"
>

  <!-- Icon + Title -->
  <div class="flex items-start gap-3 mb-4">
    <div
      class="shrink-0 w-11 h-11 rounded-xl flex items-center justify-center transition-transform group-hover:scale-110 bg-surface-900 text-brand-600 border border-border-subtle"
    >
      <Icon name="layers" size="lg" />
    </div>
    <div class="flex-1 min-w-0">
      <h3
        class="font-bold text-sm leading-tight mb-1 line-clamp-2 transition-colors group-hover:text-brand-600 text-text-primary"
      >
        {title}
      </h3>
      <div class="flex items-center gap-2">
        <ProgressBadge status={status} />
        <FavoriteButton id={id} type="learning-path" isFavorite={isFavorite} />
      </div>
    </div>
  </div>

  <!-- Description -->
  {
    description && (
      <p
        class="text-xs leading-relaxed line-clamp-3 mb-4 text-text-secondary"
        set:html={description
          .replace(/<[^>]*>/g, " ")
          .trim()
          .slice(0, 200)}
      />
    )
  }

  <!-- Progress bar + count -->
  <div class="mt-auto">
    <div class="flex items-center justify-between mb-1.5 border-none">
      <span class="text-xs text-text-muted">
        {completedCount} / {courseCount} cursos
      </span>
      <span
        class="text-xs font-semibold text-brand-400"
      >
        {progress}%
      </span>
    </div>
    <ProgressBar progress={progress} />
  </div>
</a>

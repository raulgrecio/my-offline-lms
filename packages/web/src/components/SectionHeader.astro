---
import { Icon } from "./Icon";
import type { IconName } from "./Icon/icons";

interface Props {
  id?: string;
  title: string;
  icon: IconName;
  href?: string;
}

const { id, title, icon, href } = Astro.props;
---

<div id={id} class="flex items-center justify-between mb-5">
  <h2 class="section-title">
    <Icon
      name={icon}
      size="md"
      className="text-brand-600"
    />
    {title}
  </h2>
  { href && (
  <a href={href} class="btn-ghost text-xs group">
    Ver más
    <Icon
      name="chevron-right"
      size="xs"
      className="transition-transform group-hover:translate-x-1"
    />
  </a>
  )}
</div>

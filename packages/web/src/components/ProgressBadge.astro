---
import type { AssetStatus } from "@core/domain/models/Asset";
import type { ProgressStatus } from "../features/progress/domain/model/ProgressStatus";

type StatusType = ProgressStatus | AssetStatus;

interface Props {
  status: StatusType
}

const { status } = Astro.props;

const normalized = status?.toUpperCase();

const config: Record<string, { cls: string; label: string }> = {
  COMPLETED: { cls: 'badge badge-completed', label: 'Completado' },
  IN_PROGRESS: { cls: 'badge badge-in-progress badge-pulse', label: 'En progreso' },
  NOT_STARTED: { cls: 'badge badge-not-started', label: 'Sin iniciar' },
  FAILED: { cls: 'badge badge-failed', label: 'Error' },
  PENDING: { cls: 'badge badge-not-started', label: 'Pendiente' },
  DOWNLOADING: { cls: 'badge badge-downloading badge-pulse', label: 'Descargando' },
};

const cfg = config[normalized] ?? config['NOT_STARTED'];
---

<span class={cfg.cls}>
  <span class="status-dot" aria-hidden="true"></span>
  {cfg.label}
</span>

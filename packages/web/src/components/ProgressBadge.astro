---
import type { ProgressStatus } from "@features/progress/domain/model/ProgressStatus";
import Badge, { type BadgeProps, type BadgeConfig } from "./Badge.astro";

export type { ProgressStatus };

interface Props extends BadgeProps {
  status: ProgressStatus;
}


const config: Record<ProgressStatus, BadgeConfig> = {
  completed: {
    classes: "bg-status-completed/15 text-status-completed border-status-completed/30",
    dotClasses: "bg-status-completed",
    label: "Completado",
  },
  in_progress: {
    classes: "bg-status-in-progress/15 text-status-in-progress border-status-in-progress/30",
    dotClasses: "bg-status-in-progress",
    label: "En progreso",
    pulse: true,
  },
  not_started: {
    classes: "bg-status-not-started/15 text-status-not-started border-status-not-started/30",
    dotClasses: "bg-transparent border-[1.5px] border-currentColor",
    label: "Sin iniciar",
  },
};

const { status, className = "", ...rest } = Astro.props;
const normalized = (status?.toLowerCase() || 'not_started') as ProgressStatus;
const cfg = config[normalized] ?? config["not_started"];
---

<Badge
  {...rest}
  className={`${cfg.classes} ${className}`}
  pulse={rest.pulse ?? cfg.pulse}
  dot="static"
  dotClasses={cfg.dotClasses}
>
  <slot>{cfg.label}</slot>
</Badge>

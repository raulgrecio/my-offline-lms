---
import type { AssetStatus } from "@core/domain/models/Asset";
import type { ProgressStatus } from "@features/progress/domain/model/ProgressStatus";
import Badge, { type BadgeVariant } from "./Badge.astro";

export type StatusType = ProgressStatus | AssetStatus;

interface ProgressBadgeProps {
  status: StatusType
}

const { status } = Astro.props as ProgressBadgeProps;

const normalized = status?.toUpperCase();

const config: Record<string, { variant: Partial<BadgeVariant>; label: string; pulse?: boolean }> = {
  COMPLETED: { variant: 'completed', label: 'Completado' },
  IN_PROGRESS: { variant: 'in-progress', label: 'En progreso' },
  NOT_STARTED: { variant: 'not-started', label: 'Sin iniciar' },
  FAILED: { variant: 'failed', label: 'Error' },
  PENDING: { variant: 'not-started', label: 'Pendiente' },
  DOWNLOADING: { variant: 'downloading', label: 'Descargando', pulse: true },
};

const cfg = config[normalized] ?? config['NOT_STARTED'];
---

<Badge variant={cfg.variant} pulse={cfg.pulse} dot="static">
  {cfg.label}
</Badge>

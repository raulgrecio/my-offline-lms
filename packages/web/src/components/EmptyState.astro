---
import { Icon } from "./Icon";
import type { IconName } from "./Icon/icons";

interface EmptyStateProps {
  title?: string;
  message: string;
  icon?: IconName;
}

const { title, message, icon = "inbox" } = Astro.props as EmptyStateProps;
---

<div
  class="text-center py-24 rounded-2xl bg-surface-900 border border-dashed border-border-subtle"
>
  <div class="flex justify-center mb-4">
    <div
      class="w-16 h-16 rounded-full bg-surface-800 flex items-center justify-center text-text-muted"
    >
      <Icon name={icon} size="xl" />
    </div>
  </div>
  {
    title && (
      <h2 class="text-lg font-medium text-text-primary mb-2">
        {title}
      </h2>
    )
  }
  <p class="font-medium text-text-secondary">
    {message}
  </p>
</div>

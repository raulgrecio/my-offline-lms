---
import type { CourseStatusType } from "src/features/progress/domain/model/CourseProgress";
import ProgressBadge from "./ProgressBadge.astro";

interface Props {
  id: string;
  title: string;
  status?: CourseStatusType;
  orderIndex?: number;
  assetCount?: number;
}

const {
  id,
  title,
  status = "not_started",
  orderIndex,
  assetCount,
} = Astro.props;
---

<a
  href={`/courses/${id}`}
  class="card flex items-center gap-4 p-4 group"
  style="text-decoration: none;"
>
  <!-- Order number or icon -->
  <div
    class="shrink-0 w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold"
    style="background-color: color-mix(in srgb, var(--color-oracle-600) 15%, transparent); color: var(--color-oracle-400);"
  >
    {orderIndex !== undefined ? orderIndex : "📚"}
  </div>

  <!-- Title + badge -->
  <div class="flex-1 min-w-0">
    <h4
      class="font-semibold text-sm leading-snug line-clamp-2 mb-1"
      style="color: var(--color-text-primary);"
    >
      {title}
    </h4>
    <div class="flex items-center gap-2 flex-wrap">
      <ProgressBadge status={status} />
      {
        assetCount !== undefined && (
          <span class="text-xs" style="color: var(--color-text-muted);">
            {assetCount} assets
          </span>
        )
      }
    </div>
  </div>

  <!-- Arrow -->
  <div
    class="shrink-0 text-lg transition-transform group-hover:translate-x-1"
    style="color: var(--color-text-muted);"
  >
    →
  </div>
</a>

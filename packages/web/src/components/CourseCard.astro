---
import type { CourseStatusType } from "../features/progress/domain/model/CourseProgress";
import ProgressBadge from "./ProgressBadge.astro";
import { Icon } from "./Icon";

interface Props {
  id: string;
  title: string;
  status?: CourseStatusType;
  orderIndex?: number;
  assetCount?: number;
}

const {
  id,
  title,
  status = "not_started",
  orderIndex,
  assetCount,
} = Astro.props;
---

<a
  href={`/courses/${id}`}
  class="card flex items-center gap-4 p-4 group"
  style="text-decoration: none;"
>
  <!-- Order number or icon -->
  <div
    class="shrink-0 w-10 h-10 rounded-xl flex items-center justify-center text-sm font-bold transition-transform group-hover:scale-110"
    style="background-color: var(--bg-secondary); color: var(--color-brand-600); border: 1px solid var(--border-subtle);"
  >
    {
      orderIndex !== undefined ? (
        orderIndex
      ) : (
        <Icon name="book-open" size="sm" />
      )
    }
  </div>

  <!-- Title + badge -->
  <div class="flex-1 min-w-0">
    <h4
      class="font-semibold text-sm leading-snug line-clamp-2 mb-1"
      style="color: var(--text-primary);"
    >
      {title}
    </h4>
    <div class="flex items-center gap-2 flex-wrap">
      <ProgressBadge status={status} />
      {
        assetCount !== undefined && (
          <span class="text-xs" style="color: var(--text-muted);">
            {assetCount} assets
          </span>
        )
      }
    </div>
  </div>

  <!-- Arrow -->
  <div
    class="shrink-0 transition-transform group-hover:translate-x-1"
    style="color: var(--text-muted);"
  >
    <Icon name="chevron-right" size="sm" />
  </div>
</a>

---
import type { CourseStatusType } from "../features/progress/domain/model/CourseProgress";
import ProgressBadge from "./ProgressBadge.astro";
import { Icon } from "./Icon";
import { APP_ROUTES } from "../platform/router/routes";

interface Props {
  id: string;
  title: string;
  status?: CourseStatusType;
  orderIndex?: number;
  assetCount?: number;
}

const {
  id,
  title,
  status = "not_started",
  orderIndex,
  assetCount,
} = Astro.props;
---

<a
  href={APP_ROUTES.COURSES.DETAIL(id)}
  class="card flex items-center gap-4 p-4 group no-underline"
>
  <!-- Order number or icon -->
  <div
    class="shrink-0 w-10 h-10 rounded-xl flex items-center justify-center text-sm font-bold transition-transform group-hover:scale-110 bg-surface-900 text-brand-600 border border-border-subtle"
  >
    {
      orderIndex !== undefined ? (
        orderIndex
      ) : (
        <Icon name="book-open" size="sm" />
      )
    }
  </div>

  <!-- Title + badge -->
  <div class="flex-1 min-w-0">
    <h3
      class="font-bold text-sm leading-tight mb-1 line-clamp-2 transition-colors group-hover:text-brand-600 text-text-primary"
    >
      {title}
    </h3>
    <div class="flex items-center gap-2 flex-wrap">
      <ProgressBadge status={status} />
      {
        assetCount !== undefined && (
          <span class="text-xs text-text-muted">
            {assetCount} assets
          </span>
        )
      }
    </div>
  </div>

  <!-- Arrow -->
  <div
    class="shrink-0 transition-transform group-hover:translate-x-1 text-text-muted"
  >
    <Icon name="chevron-right" size="sm" />
  </div>
</a>

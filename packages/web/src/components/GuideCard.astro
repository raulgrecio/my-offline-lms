---
import { APP_ROUTES } from "@web/platform/router/routes";
import type { AssetProgress } from "@web/features/progress/domain/model/AssetProgress";
import { Icon } from "./Icon";

interface GuideCardProps {
  assetId: string;
  courseId: string;
  name: string;
  localUrl: string;
  progress: AssetProgress | null;
  totalPages: number;
}

const { assetId, courseId, name, localUrl, progress, totalPages } = Astro.props as GuideCardProps;
const maxPosition = progress?.maxPosition || 0;
const currentPosition = progress?.position || 0;
const isDone = progress?.completed || (totalPages > 0 && maxPosition >= totalPages);

const statusText = isDone 
  ? "Completado" 
  : (currentPosition > 1 
      ? `Continuar en la pág. ${currentPosition}${totalPages ? ` de ${totalPages}` : ""}${maxPosition > currentPosition ? ` (visto hasta la ${maxPosition})` : ""}` 
      : (totalPages ? `Ver guía de ${totalPages} páginas` : "Ver guía"));
---
<a
  href={APP_ROUTES.VIEWER.GUIDE({ assetId, courseId, path: localUrl })}
  target="_blank"
  rel="noopener"
  class="card flex items-center gap-3 p-4 no-underline group"
  data-asset-id={assetId}
  data-missing-metadata={!totalPages ? "true" : "false"}
  data-is-done={isDone ? "true" : "false"}
  data-current-page={currentPosition || 0}
>
  <div
    class="shrink-0 w-10 h-10 rounded-xl flex items-center justify-center transition-transform group-hover:scale-110 bg-surface-900 text-brand-600 border border-border-subtle"
  >
    <Icon name="file-text" size="md" />
  </div>
  <div class="flex-1 min-w-0">
    <p class="text-sm font-medium line-clamp-2 text-text-primary">
      {name}
    </p>
    <div class="flex items-center gap-2 mt-1">
      <span
        class="text-2xs font-bold px-1.5 py-0.5 rounded bg-surface-900 text-text-muted"
      >PDF</span
      >
      <span class:list={[
        "text-2xs text-text-muted flex items-center gap-1",
        isDone ? "bg-brand-600/10 text-brand-600" : "text-text-muted"
      ]}>
        {isDone && <Icon name="check-circle" size="xs" />}
        <span class="status-label">{statusText}</span>
      </span>
    </div>
  </div>
</a>

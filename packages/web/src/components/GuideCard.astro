---
import { Icon } from "./Icon";

const { name, localUrl } = Astro.props;
---
<a
  href={localUrl}
  target="_blank"
  rel="noopener"
  class="card flex items-center gap-3 p-4 no-underline"
>
  <div
    class="shrink-0 w-10 h-10 rounded-xl flex items-center justify-center transition-transform group-hover:scale-110 bg-surface-900 text-brand-600 border border-border-subtle"
  >
    <Icon name="file-text" size="md" />
  </div>
  <div class="flex-1 min-w-0">
    <p
      class="text-sm font-medium line-clamp-2 text-text-primary"
    >
      {name}
    </p>
    <div class="flex items-center gap-1.5 mt-1">
      <span
        class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-surface-900 text-text-muted"
      >PDF</span
      >
      <span class="text-[10px] text-text-muted"
        >Ver guía</span
      >
    </div>
  </div>
</a>

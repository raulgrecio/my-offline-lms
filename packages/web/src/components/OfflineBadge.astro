---
import { Icon } from "./Icon";

interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<span class:list={[
  "inline-flex items-center gap-1 px-1.5 py-0.5 rounded-md bg-green-500/10 text-green-600 text-[10px] font-bold uppercase tracking-tight shrink-0",
  className
]}>
  <Icon name="check" size="xs" />
  Local
</span>

---
import { Icon } from "./Icon";

interface Props {
  title: string;
  icon: string;
  stats: string;
  showAll: boolean;
  baseUrl: string;
}

const { title, icon, stats, showAll, baseUrl } = Astro.props;

const toggleUrl = showAll ? `${baseUrl}?all=false` : baseUrl;
---

<div class="mb-8 flex items-end justify-between gap-4 flex-wrap">
  <div>
    <h1
      class="text-2xl sm:text-3xl font-bold mb-1 flex items-center gap-2 text-text-primary"
    >
      <Icon
        name={icon as any}
        size="lg"
        className="text-brand-600"
      />
      {title}
    </h1>
    <p class="text-sm text-text-secondary">
      {stats}
    </p>
  </div>

  <a
    href={toggleUrl}
    class="btn-ghost text-xs group flex items-center gap-2"
  >
    <Icon name={showAll ? "eye-off" : "eye"} size="xs" />
    {showAll ? "Ocultar vacíos" : "Ver todos"}
  </a>
</div>

---
import { Icon, type IconName } from "./Icon";

interface Props {
  title: string;
  icon: IconName;
  subtitle?: string;
}

const { title, icon, subtitle } = Astro.props;
---

<div class="flex items-center justify-between mb-8">
  <div class="space-y-1">
    <h1 class="text-3xl font-bold text-text-primary flex items-center gap-3">
      <Icon
        name={icon}
        size="md"
        className="text-brand-500"
      />
      <span id="page-header-title">{title}</span>
    </h1>
    {
      subtitle && (
        <p id="page-header-subtitle" class="text-sm text-text-secondary">
          {subtitle}
        </p>
      )
    }
  </div>

  <div class="flex items-center gap-3">
    <slot name="actions" />
  </div>
</div>

---
import { Icon } from "./Icon";
import type { IconName } from "./Icon/icons";

interface Props {
  title: string;
  subtitle?: string;
  icon?: IconName;
  initialOpen?: boolean;
}

const {
  title,
  subtitle,
  icon = "plus",
  initialOpen = false,
} = Astro.props as Props;
---

<section
  class="mb-8 border border-border-subtle bg-surface-800 rounded-2xl overflow-hidden shadow-lg transition-all"
  data-collapsible
>
  <button
    class="flex items-center justify-between w-full p-5 hover:bg-surface-700 transition-colors group text-left outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
    data-collapsible-trigger
    aria-expanded={initialOpen ? "true" : "false"}
  >
    <div class="flex items-center gap-3">
      {
        icon && (
          <div class="w-10 h-10 rounded-xl flex items-center justify-center bg-brand-600/10 text-brand-600 group-hover:scale-110 transition-transform">
            <Icon name={icon} size="md" />
          </div>
        )
      }
      <div>
        <span class="block font-bold text-text-primary leading-tight">
          {title}
        </span>
        {
          subtitle && (
            <span class="block text-[11px] text-text-muted mt-0.5 leading-tight">
              {subtitle}
            </span>
          )
        }
      </div>
    </div>
    <div
      class={`text-text-muted transition-transform duration-300 ${
        initialOpen ? "rotate-180" : ""
      }`}
      data-collapsible-icon
    >
      <Icon name="chevron-down" size="sm" />
    </div>
  </button>

  <div
    class={`border-t border-border-subtle p-6 bg-surface-800/50 ${
      initialOpen ? "" : "hidden"
    }`}
    data-collapsible-content
  >
    <slot />
  </div>
</section>

<script>
  function initCollapsibles() {
    document.querySelectorAll("[data-collapsible]").forEach((card) => {
      if (card.getAttribute("data-active")) return;
      card.setAttribute("data-active", "true");

      const btn = card.querySelector("[data-collapsible-trigger]");
      const content = card.querySelector("[data-collapsible-content]");
      const icon = card.querySelector("[data-collapsible-icon]");

      btn?.addEventListener("click", () => {
        const isHidden = content?.classList.contains("hidden");
        content?.classList.toggle("hidden");
        icon?.classList.toggle("rotate-180", isHidden);
        btn.setAttribute("aria-expanded", String(isHidden));
      });
    });
  }

  initCollapsibles();
  document.addEventListener("astro:page-load", initCollapsibles);
  document.addEventListener("astro:after-swap", initCollapsibles);
</script>

---
import { API_ROUTES } from "@web/platform/api/routes";
import type { FavoriteType } from "@web/features/favorites/domain/ports/IFavoritesRepository";
import Button, {
  type ButtonSize,
  type ButtonHoverEffect,
} from "./Button.astro";
import { cn } from "@web/lib/cn";

interface FavoriteButtonProps {
  id: string;
  type: FavoriteType;
  isFavorite?: boolean;
  size?: ButtonSize;
  hoverEffect?: Exclude<ButtonHoverEffect, "none">;
  className?: string;
}

const {
  id,
  type,
  isFavorite = false,
  size = "sm",
  hoverEffect = "scale",
  className = "",
} = Astro.props as FavoriteButtonProps;

const favoritesUrl = API_ROUTES.FAVORITES.TOGGLE;
---

<Button
  variant="ghost"
  size={size}
  hoverEffect={hoverEffect}
  square
  icon="heart"
  iconClass={cn(
    "transition-all duration-300",
    "group-data-[is-favorite=true]/fav:fill-current group-data-[is-favorite=false]/fav:fill-none"
  )}
  class={cn(
    "favorite-toggle group/fav shadow-elevation border transition-all duration-300",
    "data-[is-favorite=true]:text-brand-500 data-[is-favorite=true]:bg-brand-600/10 data-[is-favorite=true]:border-brand-500/20 data-[is-favorite=true]:shadow-brand/20",
    "data-[is-favorite=false]:bg-surface-800 data-[is-favorite=false]:border-border-subtle data-[is-favorite=false]:text-text-muted hover:data-[is-favorite=false]:text-brand-400 hover:data-[is-favorite=false]:bg-surface-700 hover:data-[is-favorite=false]:border-brand-500/30",
    className
  )}
  data-id={id}
  data-type={type}
  data-url={favoritesUrl}
  data-is-favorite={isFavorite.toString()}
  title={isFavorite ? "Quitar de favoritos" : "Añadir a favoritos"}
  aria-pressed={isFavorite ? "true" : "false"}
/>

<style>
  @reference "../styles/global.css";

  /* Loading state */
  .favorite-toggle[data-loading="true"] {
    @apply opacity-70 cursor-wait;
  }
</style>

<script>
  import { logger } from "@web/platform/logging";
  import { apiClient } from "@web/platform/api/client";

  // Handle favorites toggle using event delegation.
  // Astro bundles this script once per page.
  document.addEventListener("click", async (event) => {
    const btn = (event.target as HTMLElement).closest(
      ".favorite-toggle"
    ) as HTMLButtonElement;
    if (!btn) return;

    // Crucial: stop propagation to prevent parent link navigation
    event.preventDefault();
    event.stopPropagation();

    // Prevent concurrent requests
    if (btn.dataset.loading === "true") return;

    const { id, type, url: favoritesUrl, isFavorite } = btn.dataset;
    if (!id || !type || !favoritesUrl) return;

    const wasFavorite = isFavorite === "true";
    const nextFavorite = !wasFavorite;

    // --- OPTIMISTIC UI UPDATE ---
    updateButtonState(btn, nextFavorite);
    btn.dataset.loading = "true";

    try {
      const data = await apiClient.post<{ ok: boolean }>(favoritesUrl, {
        id,
        type,
      });

      if (!data.ok) throw new Error("API reported failure");

      // Successfully toggled. No reload needed.
      logger.info(`Favorite toggled for ${type} ${id}: ${nextFavorite}`);
    } catch (err) {
      logger.error("Failed to toggle favorite:", err);
      // REVERT on error
      updateButtonState(btn, wasFavorite);
    } finally {
      delete btn.dataset.loading;
    }
  });

  function updateButtonState(btn: HTMLButtonElement, isFav: boolean) {
    btn.dataset.isFavorite = isFav.toString();
    btn.setAttribute("aria-pressed", isFav.toString());
    btn.title = isFav ? "Quitar de favoritos" : "Añadir a favoritos";
  }
</script>

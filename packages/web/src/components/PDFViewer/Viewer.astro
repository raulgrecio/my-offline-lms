---
import { API_ROUTES } from "@platform/api/routes";
import SaveIndicator from "./SaveIndicator.astro";
import ViewerHeader from "./ViewerHeader.astro";
import ViewerMain from "./ViewerMain.astro";
import ViewerSidebar from "./ViewerSidebar.astro";

interface ViewerProps {
  assetId: string;
  courseId: string;
  path: string;
  initialPage: number;
}

const { assetId, courseId, path, initialPage } = Astro.props as ViewerProps;
---

<div 
  id="viewer-root"
  class="flex flex-col h-screen overflow-hidden bg-surface-950 text-text-primary"
  data-asset-id={assetId}
  data-course-id={courseId}
  data-path={path}
  data-initial-page={initialPage}
  data-progress-url={API_ROUTES.PROGRESS.GUIDE}
  data-metadata-url={API_ROUTES.ASSETS.METADATA()}
>
  <ViewerHeader path={path} />

  <div class="flex flex-1 overflow-hidden relative">
    <ViewerSidebar />
    <ViewerMain />
    <SaveIndicator />
  </div>
</div>

<script>
  import { initPdfViewer } from "./pdf-viewer-client";

  const root = document.getElementById('viewer-root') as HTMLElement;
  if (root) {
    const assetId = root.dataset.assetId!;
    const courseId = root.dataset.courseId!;
    const path = root.dataset.path!;
    const initialPage = parseInt(root.dataset.initialPage || '1');
    const progressUrl = root.dataset.progressUrl!;
    const metadataUrl = root.dataset.metadataUrl!;
    
    initPdfViewer({assetId, courseId, path, initialPage, options: { progressUrl, metadataUrl }});
  }
</script>

<style>
  .thumb-wrapper.ring-2 {
    transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    transform: scale(1.05);
  }
  
  canvas {
    image-rendering: -webkit-optimize-contrast;
  }

  .page-wrapper {
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease;
  }
</style>

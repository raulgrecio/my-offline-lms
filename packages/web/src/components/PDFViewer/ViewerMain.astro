---
import { Icon } from "../Icon";
---

<main 
  id="pdf-container" 
  class="flex-1 overflow-y-auto p-4 sm:p-8 flex flex-col items-center gap-12 custom-scrollbar bg-surface-950 relative"
>
  <div id="loading" class="flex flex-col items-center gap-4 py-20 pointer-events-none sticky top-1/2 -translate-y-1/2">
    <div class="w-10 h-10 border-4 border-brand-600 border-t-transparent rounded-full animate-spin"></div>
    <p class="text-sm text-text-muted">Preparando documento...</p>
  </div>
</main>

<!-- ─── Templates ────────────────────────────────────────────────────────── -->
<template id="page-template">
  <div data-page-row class="page-wrapper relative bg-surface-900 shadow-[0_10px_30px_rgba(0,0,0,0.5)] opacity-30">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-8 h-8 border-2 border-brand-600/30 border-t-brand-600 rounded-full animate-spin"></div>
  </div>
</template>

<template id="error-template">
  <div class="p-12 text-center max-w-md mx-auto">
    <div class="flex justify-center mb-4 text-red-500/50">
      <Icon name="alert-circle" size="xl" />
    </div>
    <h3 class="text-lg font-bold text-text-primary mb-2">Error al cargar el documento</h3>
    <p data-error-message class="text-sm text-text-secondary leading-relaxed"></p>
    <button onclick="location.reload()" class="mt-6 btn-ghost text-xs border border-border-subtle">
      Reintentar carga
    </button>
  </div>
</template>

<style>
  .page-wrapper {
    transition: opacity 0.3s ease;
  }
</style>

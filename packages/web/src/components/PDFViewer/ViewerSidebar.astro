<aside 
  id="pdf-sidebar" 
  class="w-0 sm:w-64 bg-surface-900 border-r border-border-subtle overflow-y-auto overflow-x-hidden shrink-0 transition-[width] duration-300 custom-scrollbar opacity-0 sm:opacity-100"
>
  <div id="thumbnails-container" class="flex flex-col gap-6 p-4 items-center">
     <!-- Thumbnails will be injected here -->
  </div>
</aside>

<!-- ─── Templates ────────────────────────────────────────────────────────── -->
<template id="thumb-template">
  <div data-thumb-row class="thumb-wrapper group relative cursor-pointer transition-all duration-200 p-1.5 rounded-xl hover:bg-surface-700 flex flex-col items-center border border-transparent hover:border-border-subtle/50">
    <div data-thumb-canvas class="bg-surface-950 rounded-lg border border-border-subtle overflow-hidden flex items-center justify-center shadow-lg">
      <span data-thumb-placeholder class="text-2xs text-text-muted opacity-30"></span>
    </div>
    <span data-thumb-label class="text-center text-[10px] mt-2 font-bold text-text-muted group-hover:text-brand-500 transition-colors tracking-tight"></span>
  </div>
</template>

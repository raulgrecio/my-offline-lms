---
import { Icon } from "../Icon";
import type { IconName } from "../Icon/icons";

interface Props {
  id?: string;
  title: string;
  icon: IconName;
  href?: string;
  className?: string;
  iconSize?: "xs" | "sm" | "md";
  variant?: "ghost" | "zoom" | "none"; 
  [key: string]: any; 
}

const { 
  id, 
  title, 
  icon, 
  href, 
  className = "", 
  iconSize = "sm", 
  variant = "ghost",
  ...rest 
} = Astro.props;

const variants: Record<string, string> = {
  ghost: "p-2 rounded-lg hover:bg-surface-800 text-text-secondary hover:text-text-primary transition-colors",
  zoom: "p-1 rounded hover:bg-surface-700 text-text-secondary transition-colors disabled:opacity-30",
  none: ""
};

const Tag = href ? "a" : "button";
const classes = `${variants[variant]} ${className}`;
---

<Tag 
  id={id} 
  title={title} 
  href={href} 
  class={classes} 
  {...rest}
>
  <Icon name={icon} size={iconSize} />
</Tag>

---
import { Icon } from "./Icon";

interface Props {
  lastWatched?: any;
  lastWatchedCourse?: any;
}

const { lastWatched, lastWatchedCourse } = Astro.props;
---

<section class="mb-12 relative overflow-hidden rounded-3xl group">
  <!-- Background layers -->
  <div
    class="absolute inset-0 bg-linear-to-br from-surface-800 via-surface-800 to-brand-900/20"
  >
  </div>
  <div
    class="absolute -right-20 -top-20 opacity-5 transition-transform duration-700 group-hover:scale-110 group-hover:-rotate-12"
  >
    <Icon name={lastWatched ? "play" : "rocket"} size="12xl" />
  </div>

  <div class="relative p-8 sm:p-12 flex flex-col items-start gap-8">
    {
      lastWatched ? (
        <div class="max-w-2xl">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-600/10 border border-brand-600/20 text-brand-400 text-2xs font-bold uppercase tracking-widest mb-6">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75" />
              <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-500" />
            </span>
            Continuar viendo
          </div>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-tight mb-4 text-text-primary tracking-tight">
            {lastWatched.metadata?.name ?? "Vídeo"}
          </h2>
          {lastWatchedCourse && (
            <p class="text-lg text-text-secondary leading-relaxed mb-8 flex items-center gap-2">
              <Icon name="book-open" size="sm" className="text-brand-600" />
              {lastWatchedCourse.title}
            </p>
          )}
          <a
            href={`/courses/${lastWatched.courseId}`}
            class="btn-primary px-8 py-4 text-base shadow-brand/50 hover:shadow-brand transition-all flex items-center gap-3 w-full sm:w-auto justify-center"
          >
            <Icon name="play" size="sm" strokeWidth={3} />
            Continuar ahora
          </a>
        </div>
      ) : (
        <div class="max-w-2xl">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-600/10 border border-brand-600/20 text-brand-400 text-2xs font-bold uppercase tracking-widest mb-6">
            Bienvenido de nuevo
          </div>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-tight mb-4 text-text-primary tracking-tight">
            Comienza ahora tu formación
          </h2>
          <p class="text-lg text-text-secondary leading-relaxed mb-8">
            Explora tu catálogo offline y continúa aprendiendo desde donde lo
            dejaste, sin necesidad de conexión.
          </p>
          <a
            href="#cursos-section"
            class="btn-primary px-8 py-4 text-base shadow-brand/50 hover:shadow-brand transition-all flex items-center gap-3 w-full sm:w-auto justify-center"
          >
            Explorar cursos
            <Icon name="arrow-right" size="sm" strokeWidth={2.5} />
          </a>
        </div>
      )
    }
  </div>
</section>

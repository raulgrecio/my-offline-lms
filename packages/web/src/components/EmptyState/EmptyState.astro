---
import { EmptyState as ReactEmptyState } from "./EmptyState";
import type { IconName } from "./Icon/icons";

interface EmptyStateProps {
  title?: string;
  message: string;
  icon?: IconName;
  variant?: "empty" | "loading";
}

const {
  title,
  message,
  icon = "inbox",
  variant = "empty",
} = Astro.props as EmptyStateProps;
---

<ReactEmptyState
  client:visible
  title={title}
  message={message}
  icon={icon}
  variant={variant}
>
  <slot name="action" />
</ReactEmptyState>

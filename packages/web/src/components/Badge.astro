---
const variantClasses = {
  'brand': 'bg-brand-600/10 text-brand-400 border-brand-600/20',
  'neutral': 'bg-surface-800 text-text-secondary border-border-subtle',
} as const;

export type BadgeVariant = keyof typeof variantClasses;

export interface BadgeProps {
  variant?: BadgeVariant;
  pulse?: boolean;
  dot?: 'none' | 'static' | 'pulse';
  dotClasses?: string;
  className?: string;
  ariaLabel?: string;
  dataStatus?: string;
}

export interface BadgeConfig { 
  classes: string; 
  dotClasses?: string; 
  label: string; 
  pulse?: boolean 
}

const { 
  variant,
  pulse = false, 
  dot = 'none',
  dotClasses = '',
  className = '',
  ariaLabel,
  dataStatus
} = Astro.props as BadgeProps;

const baseClasses = "inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[0.7rem] font-bold uppercase tracking-wider border transition-all duration-200";

const dotColorClasses: Partial<Record<BadgeVariant, string>> = {
  'brand': 'bg-brand-500',
  'neutral': 'bg-text-muted',
} as const;

const finalVariantClass = variant ? (variantClasses[variant as BadgeVariant] || variantClasses['neutral']) : '';
const finalDotClasses = dotClasses || (variant ? dotColorClasses[variant as BadgeVariant] : 'bg-currentColor');

const classes = [
  baseClasses,
  finalVariantClass,
  pulse ? 'animate-pulse' : '',
  className
].filter(Boolean).join(' ');

const hasCustomDot = Astro.slots.has('dot');
const showDefaultDot = !hasCustomDot && dot !== 'none';
---

<span 
  class={classes} 
  aria-label={ariaLabel} 
  data-status={dataStatus}
  role={ariaLabel ? "status" : undefined}
>
  {hasCustomDot && <slot name="dot" />}

  {showDefaultDot && (
    <div 
      class:list={[
        "w-1.5 h-1.5 rounded-full shrink-0 relative",
        finalDotClasses,
        dot === 'pulse' && "after:content-[''] after:absolute after:inset-0 after:rounded-full after:bg-currentColor after:animate-ping"
      ]} 
      aria-hidden="true" 
    />
  )}

  <slot />
</span>

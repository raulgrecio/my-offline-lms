---
import { Icon } from "@web/ui/primitives/Icon";

interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<span class:list={[
  "inline-flex items-center gap-1 px-1.5 py-0.5 rounded-md bg-status-completed/10 text-status-completed text-2xs font-bold uppercase tracking-tight shrink-0",
  className
]}>
  <Icon name="check" size="xs" />
  Local
</span>

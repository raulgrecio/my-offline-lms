---
import { Icon } from "@web/ui/primitives/Icon";
import type { IconName } from "@web/ui/primitives/Icon";

interface Props {
  icon: IconName;
  title: string;
  subtitle: string;
}

const { icon, title, subtitle } = Astro.props;
---

<div class="flex items-center gap-4 group/header">
  <div
    class="w-10 h-10 rounded-xl flex items-center justify-center bg-brand-600/10 text-brand-600 group-hover:scale-110 transition-all duration-300 shadow-sm border border-brand-500/5"
  >
    <Icon name={icon} size="md" />
  </div>
  <div class="space-y-0.5">
    <span
      class="block font-bold text-text-primary leading-tight"
    >
      {title}
    </span>
    <span
      class="block text-xs text-text-muted leading-tight opacity-70"
    >
      {subtitle}
    </span>
  </div>
</div>

---
import Button from "@web/ui/components/Button/Button.astro";
import { Icon } from "@web/ui/primitives/Icon";
import type { IconName } from "@web/ui/primitives/Icon/icons";

interface SectionHeaderProps {
  id?: string;
  title: string;
  icon?: IconName;
  href?: string;
}

const { id, title, icon, href } = Astro.props as SectionHeaderProps;
---

<div id={id} class="flex items-center justify-between mb-5">
  <h2 class="section-title">
    {icon && <Icon name={icon} size="md" className="text-brand-600" />}
    {title}
  </h2>
  {
    href && (
      <Button
        href={href}
        variant="outline"
        size="sm"
        iconRight="chevron-right"
        iconRightClass="transition-transform duration-200 group-hover:translate-x-1"
      >
        Ver más
      </Button>
    )
  }
</div>

---
import { Icon } from "@web/ui/primitives/Icon";
import type { IconName } from "@web/ui/primitives/Icon/icons";
import ProgressBadge, { type ProgressStatus } from "@web/ui/components/ProgressBadge.astro";

interface PageHeaderProps {
  title: string;
  icon: IconName;
  status?: ProgressStatus;
  subtitle?: string;
}

const { title, icon, status, subtitle } = Astro.props as PageHeaderProps;
---

<div class="mb-8">
  <div class="flex flex-col sm:flex-row items-start gap-4 mb-4">
    <div
      class="shrink-0 w-14 h-14 rounded-xl flex items-center justify-center bg-surface-900 text-brand-600 border border-border-subtle shadow-sm"
    >
      <Icon name={icon} size="xl" />
    </div>
    <div class="flex-1 min-w-0">
      <h1
        class="text-xl sm:text-2xl font-bold leading-snug mb-2 text-text-primary"
      >
        {title}
      </h1>
      <div class="flex items-center gap-3 flex-wrap">
        {status && <ProgressBadge status={status} />}
        {subtitle && <span class="text-xs text-text-muted">{subtitle}</span>}
      </div>
    </div>
    <div class="flex items-end gap-3 shrink-0 sm:self-end">
      <slot name="actions" />
    </div>
  </div>

  {
    Astro.slots.has("default") && (
      <div class="space-y-4">
        <slot />
      </div>
    )
  }
</div>

---
import ViewerButton from "./ViewerButton.astro";
import ViewerFitControl from "./ViewerFitControl.astro";

interface ViewerHeaderProps {
  path: string;
}

const { path } = Astro.props as ViewerHeaderProps;
---

<header
  class="relative flex items-center justify-between px-4 py-2 bg-surface-900 border-b border-border-subtle shrink-0 z-20 shadow-md"
>
  <!-- Left: Sidebar Toggle & Title -->
  <div class="flex items-center gap-3 flex-1 min-w-0">
    <ViewerButton
      id="btn-sidebar"
      title="Miniaturas"
      icon="sidebar"
      variant="ghost"
    />
    <div class="w-px h-6 bg-border-subtle hidden sm:block"></div>
    <ViewerButton
      title="Cerrar visor"
      icon="arrow-left"
      onclick="window.close()"
      variant="ghost"
      className="cursor-pointer"
    />
    <h1
      class="text-xs sm:text-sm font-semibold truncate hidden md:block"
      id="pdf-title"
    >
      Cargando...
    </h1>
  </div>

  <!-- Center: Navigation & Zoom -->
  <div
    class="flex items-center gap-2 sm:gap-6 bg-surface-950/50 px-4 py-1.5 rounded-xl border border-border-subtle/50 shadow-inner"
  >
    <!-- Page Nav -->
    <div class="flex items-center gap-1.5">
      <input
        type="number"
        id="page-input"
        min="1"
        class="w-8 sm:w-10 bg-surface-800/50 border border-border-subtle/30 px-0.5 py-0.5 text-center text-xs text-text-primary focus:outline-none focus:text-brand-400 focus:border-brand-500/50 transition-all [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
        value="1"
      />
      <span class="text-2xs text-text-secondary">/</span>
      <span id="total-pages" class="text-xs text-text-secondary min-w-[12px]"
        >0</span
      >
    </div>

    <div class="w-px h-4 bg-border-subtle/50"></div>

    <!-- Zoom Controls -->
    <div class="flex items-center gap-1 sm:gap-2">
      <ViewerButton
        id="btn-zoom-out"
        title="Alejar"
        icon="minus"
        variant="zoom"
        iconSize="xs"
      />

      <div class="relative group flex items-center">
        <input
          type="text"
          id="zoom-input"
          class="w-10 sm:w-12 bg-surface-800/50 border border-border-subtle/30 px-0.5 py-0.5 text-center text-2xs sm:text-xs text-text-secondary focus:outline-none focus:text-brand-400 focus:border-brand-500/50 transition-all [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
          value="100%"
        />
      </div>

      <ViewerButton
        id="btn-zoom-in"
        title="Acercar"
        icon="plus"
        variant="zoom"
        iconSize="xs"
      />
    </div>

    <div class="w-px h-4 bg-border-subtle/50 hidden sm:block"></div>

    <!-- Fit Controls (Segmented Switch) -->
    <ViewerFitControl />
  </div>

  <!-- Right: Rotate & Original -->
  <div class="flex items-center gap-1 sm:gap-3 flex-1 justify-end">
    <ViewerButton
      id="btn-help"
      title="Ayuda (Atajos de teclado)"
      icon="help-box"
      variant="ghost"
    />
    <div class="w-px h-6 bg-border-subtle mx-1"></div>
    <ViewerButton
      id="btn-rotate"
      title="Rotar"
      icon="rotate-cw"
      variant="ghost"
    />
    <div class="w-px h-6 bg-border-subtle mx-1"></div>
    <ViewerButton
      id="btn-original"
      title="Ver original"
      icon="external-link"
      href={path}
      target="_blank"
      variant="ghost"
    />
  </div>

  <slot name="footer" />
</header>

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "better-sqlite3", "vitest"],
    "outDir": "./dist",
    "baseUrl": ".",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "paths": {
      "@domain/*": ["src/domain/*"],
      "@database/*": ["src/database/*"],
      "@filesystem/*": ["src/filesystem/*"],
      "@logging": ["src/logging"]
    }
  },
  "include": ["src/**/*", "test/**/*"]
}
